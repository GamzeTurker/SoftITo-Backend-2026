@model FitnessHubMVC.Models.Member

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="font-weight:700;color:var(--tx)">Edit Member</h2>

        <a asp-action="Index" class="btn btn-outline-light btn-sm">
            Back to List
        </a>
    </div>

    <div class="table-card">

        <form asp-action="Edit" method="post">

            <input type="hidden" asp-for="MemberId" />

            <div class="row g-3">

                <div class="col-md-6">
                    <label class="form-label">Full Name</label>
                    <input asp-for="FullName" class="form-control nexus-input" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Age</label>
                    <input asp-for="Age" class="form-control nexus-input" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Membership Type</label>
                    <input asp-for="MembershipType" class="form-control nexus-input" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Join Date</label>
                    <input asp-for="JoinDate" type="date" class="form-control nexus-input" />
                </div>

                <div class="col-12 mt-3">
                    <button type="submit" class="btn btn-success w-100 py-2">
                        Update Member
                    </button>
                </div>

            </div>

        </form>

    </div>
</div>