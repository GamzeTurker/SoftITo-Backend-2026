@model IEnumerable<FitnessHubMVC.Models.Member>

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="font-weight:700;color:var(--tx)">Members</h2>

        <a asp-action="Create"
           class="btn btn-sm"
           style="background: linear-gradient(135deg, var(--pur), #8b5cf6); color:#fff; border:none; border-radius:10px;">
            + Create
        </a>
    </div>

    <div class="table-card">

        <table class="table table-nexus align-middle mb-0">

            <thead>
                <tr>
                    <th>ID</th>
                    <th>Full Name</th>
                    <th>Age</th>
                    <th>Membership</th>
                    <th>Join Date</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.MemberId</td>
                        <td class="fw-semibold">@item.FullName</td>
                        <td>@item.Age</td>
                        <td>@item.MembershipType</td>
                        <td>@item.JoinDate.ToString("yyyy-MM-dd")</td>

                        <td class="d-flex gap-2 justify-content-end">

                            <a asp-action="Edit" asp-route-id="@item.MemberId"
                               class="btn btn-sm"
                               style="background: rgba(59,130,246,.15); color:#60a5fa; border:1px solid rgba(59,130,246,.3); border-radius:10px;">
                                Edit
                            </a>

                            <a asp-action="Delete" asp-route-id="@item.MemberId"
                               class="btn btn-sm"
                               style="background: rgba(239,68,68,.15); color:#f87171; border:1px solid rgba(239,68,68,.3); border-radius:10px;">
                                Delete
                            </a>

                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>
</div>