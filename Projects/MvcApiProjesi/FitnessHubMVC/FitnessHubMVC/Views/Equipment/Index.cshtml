@model IEnumerable<FitnessHubMVC.Models.Equipment>

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="font-weight:700;color:var(--tx)">Equipment</h2>

        <a asp-action="Create"
           class="btn btn-sm"
           style="background: linear-gradient(135deg, var(--pur), #8b5cf6); color:#fff; border:none; border-radius:10px;">
            + Create
        </a>
    </div>

    <div class="table-card">

        <table class="table table-nexus align-middle mb-0">

            <thead>
                <tr>
                    <th>ID</th>
                    <th>EquipmentName</th>
                    <th>Quantity</th>
                    <th>Brand</th>
                    <th>Purchase Date</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.EquipmentId</td>
                        <td class="fw-semibold">@item.EquipmentName</td>
                        <td>@item.Quantity</td>
                        <td>@item.Brand</td>
                        <td>@item.PurchaseDate/td>

                        <td class="d-flex gap-2 justify-content-end">

                            <a asp-action="Edit" asp-route-id="@item.EquipmentId"
                               class="btn btn-sm"
                               style="background: rgba(59,130,246,.15); color:#60a5fa; border:1px solid rgba(59,130,246,.3); border-radius:10px;">
                                Edit
                            </a>

                            <a asp-action="Delete" asp-route-id="@item.EquipmentId"
                               class="btn btn-sm"
                               style="background: rgba(239,68,68,.15); color:#f87171; border:1px solid rgba(239,68,68,.3); border-radius:10px;">
                                Delete
                            </a>

                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>
</div>