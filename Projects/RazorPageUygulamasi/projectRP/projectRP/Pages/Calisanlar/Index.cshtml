@page
@model projectRP.Pages.Calisanlar.IndexModel
@{
    ViewData["Title"] = "Çalışanlar Listesi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">Çalışanlar Portal</h2>
        <p class="text-muted small mb-0">Şirket içi departman personellerini, pozisyonlarını ve maaş bilgilerini yönetin.</p>
    </div>
    <a class="btn btn-primary shadow-sm" href="/Calisanlar/Create">
        <i class="fa-solid fa-plus me-1"></i> Yeni Çalışan Ekle
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Ad Soyad</th>
                        <th>Departman</th>
                        <th>Pozisyon</th>
                        <th>Maaş</th>
                        <th>Telefon</th>
                        <th class="text-end pe-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.listele != null && Model.listele.Any())
                    {
                        foreach (var item in Model.listele)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold text-dark">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded-circle bg-success-subtle text-success d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; font-size: 13px;">
                                            <i class="fa-solid fa-user-tie"></i>
                                        </div>
                                        <span>@item.AdSoyad</span>
                                    </div>
                                </td>
                                <td><span class="badge bg-primary-subtle text-primary">@item.Departman</span></td>
                                <td>@item.Pozisyon</td>
                                <td class="fw-bold text-dark">@item.Maas.ToString("C0", new System.Globalization.CultureInfo("tr-TR"))</td>
                                <td>@item.Telefon</td>
                                <td class="text-end pe-4">
                                    <div class="d-inline-flex gap-2">
                                        <a class="btn btn-outline-warning btn-sm" href="/Calisanlar/Edit?id=@item.ID">
                                            <i class="fa-solid fa-pen-to-square"></i> Düzenle
                                        </a>
                                        <a class="btn btn-outline-danger btn-sm" href="/Calisanlar/Delete?id=@item.ID">
                                            <i class="fa-solid fa-trash"></i> Sil
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-circle-info fa-2x mb-3 d-block"></i>
                                Kayıtlı çalışan personel bulunamadı.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>