<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - CRM Yönetim Paneli</title>
    
    <!-- Google Fonts & FontAwesome -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <!-- Bootstrap & Custom CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

    <div class="app-wrapper">
        <!-- SOL SIDEBAR (MENÜ) -->
        <aside class="app-sidebar" id="sidebar">
            <div class="sidebar-header">
                <a class="sidebar-brand" asp-page="/Index">
                    <i class="fa-solid fa-square-poll-vertical text-primary"></i>
                    <span>CRM PORTAL</span>
                </a>
            </div>
            
            <ul class="sidebar-nav">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "active" : "")" 
                       asp-page="/Index">
                        <i class="fa-solid fa-chart-line"></i>
                        <span>Ana Sayfa</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Yoneticiler") == true ? "active" : "")" 
                       asp-page="/Yoneticiler/Index">
                        <i class="fa-solid fa-user-shield"></i>
                        <span>Yöneticiler</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Calisanlar") == true ? "active" : "")" 
                       asp-page="/Calisanlar/Index">
                        <i class="fa-solid fa-user-gear"></i>
                        <span>Çalışanlar</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Musteriler") == true ? "active" : "")" 
                       asp-page="/Musteriler/Index">
                        <i class="fa-solid fa-users"></i>
                        <span>Müşteriler</span>
                    </a>
                </li>
            </ul>

            <div class="sidebar-footer">
                <div>© 2026 CRM System</div>
                <small class="text-muted">v1.0.0 Stable</small>
            </div>
        </aside>

        <!-- SAĞ İÇERİK ALANI -->
        <div class="main-content">
            <!-- ÜST HEADER (BİLGİ & ARAMA) -->
            <header class="top-header">
                <div class="d-flex align-items-center">
                    <button class="btn btn-light d-lg-none me-2" type="button" onclick="toggleSidebar()">
                        <i class="fa-solid fa-bars"></i>
                    </button>
                    <div class="page-title-area">
                        <h4>CRM Control Center</h4>
                    </div>
                </div>
                
                <div class="d-flex align-items-center gap-3">
                    <div class="user-profile">
                        <div class="user-avatar">A</div>
                        <div class="d-none d-md-block text-start">
                            <span class="d-block fw-semibold" style="font-size: 14px;">Admin</span>
                            <small class="text-muted d-block" style="font-size: 11px;">Sistem Yöneticisi</small>
                        </div>
                    </div>
                </div>
            </header>

            <!-- ANA GÖVDE İÇERİĞİ -->
            <main class="content-body">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- JS Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            sidebar.classList.toggle('show');
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
