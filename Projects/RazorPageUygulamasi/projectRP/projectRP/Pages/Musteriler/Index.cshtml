@page
@model projectRP.Pages.Musteriler.IndexModel
@{
    ViewData["Title"] = "Müşteriler Listesi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">Müşteriler Portal</h2>
        <p class="text-muted small mb-0">Müşteri portföyünü, iletişim adreslerini ve özel müşteri notlarını yönetin.</p>
    </div>
    <a class="btn btn-primary shadow-sm" href="/Musteriler/Create">
        <i class="fa-solid fa-plus me-1"></i> Yeni Müşteri Ekle
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Ad Soyad</th>
                        <th>E-Posta Adresi</th>
                        <th>Telefon</th>
                        <th>Şehir</th>
                        <th>Müşteri Notları</th>
                        <th class="text-end pe-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.listele != null && Model.listele.Any())
                    {
                        foreach (var item in Model.listele)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold text-dark">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded-circle bg-danger-subtle text-danger d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; font-size: 13px;">
                                            <i class="fa-solid fa-user-tag"></i>
                                        </div>
                                        <span>@item.AdSoyad</span>
                                    </div>
                                </td>
                                <td>@item.Eposta</td>
                                <td>@item.Telefon</td>
                                <td><span class="badge bg-light text-dark border"><i class="fa-solid fa-location-dot text-muted me-1"></i>@item.Sehir</span></td>
                                <td class="text-muted small" style="max-width: 200px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                    @item.Notlar
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-inline-flex gap-2">
                                        <a class="btn btn-outline-warning btn-sm" href="/Musteriler/Edit?id=@item.ID">
                                            <i class="fa-solid fa-pen-to-square"></i> Düzenle
                                        </a>
                                        <a class="btn btn-outline-danger btn-sm" href="/Musteriler/Delete?id=@item.ID">
                                            <i class="fa-solid fa-trash"></i> Sil
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-circle-info fa-2x mb-3 d-block"></i>
                                Kayıtlı müşteri bulunamadı.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>