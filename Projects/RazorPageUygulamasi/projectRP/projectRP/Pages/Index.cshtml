@page
@model IndexModel
@{
    ViewData["Title"] = "CRM Dashboard";
}

<!-- HOŞ GELDİNİZ BANNER -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card bg-primary text-white border-0 shadow-sm overflow-hidden">
            <div class="card-body p-4 p-md-5">
                <div class="row align-items-center">
                    <div class="col-lg-8">
                        <h1 class="fw-bold mb-2">CRM Yönetim Paneline Hoş Geldiniz</h1>
                        <p class="mb-0 opacity-75">Sistemdeki yöneticileri, çalışanları ve müşteri kayıtlarını tek bir panelden kolayca yönetin. Aşağıdan güncel kayıtlara ve sistem verilerine göz atabilirsiniz.</p>
                    </div>
                    <div class="col-lg-4 text-lg-end d-none d-lg-block">
                        <i class="fa-solid fa-chart-line fa-5x opacity-25"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ANALİTİK KARTLAR -->
<div class="row g-4 mb-4">
    <!-- Yöneticiler Kartı -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 text-center p-4">
            <div class="card-body">
                <div class="bg-primary-subtle text-primary rounded-circle d-inline-flex align-items-center justify-content-center p-3 mb-3" style="width: 64px; height: 64px;">
                    <i class="fa-solid fa-user-shield fa-2x"></i>
                </div>
                <h4 class="card-title text-dark fw-bold mb-2">Yöneticiler</h4>
                <h1 class="display-5 fw-extrabold text-dark mb-2">@Model.YoneticiSayisi</h1>
                <p class="text-muted small mb-4">Toplam kayıtlı yönetici hesabı</p>
                <div class="d-grid">
                    <a href="/Yoneticiler/Index" class="btn btn-primary shadow-sm">
                        <i class="fa-solid fa-arrow-right me-1"></i> Listeyi Yönet
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Çalışanlar Kartı -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 text-center p-4">
            <div class="card-body">
                <div class="bg-success-subtle text-success rounded-circle d-inline-flex align-items-center justify-content-center p-3 mb-3" style="width: 64px; height: 64px;">
                    <i class="fa-solid fa-user-gear fa-2x"></i>
                </div>
                <h4 class="card-title text-dark fw-bold mb-2">Çalışanlar</h4>
                <h1 class="display-5 fw-extrabold text-dark mb-2">@Model.CalisanSayisi</h1>
                <p class="text-muted small mb-4">Toplam kayıtlı çalışan personeller</p>
                <div class="d-grid">
                    <a href="/Calisanlar/Index" class="btn btn-success shadow-sm" style="background-color: var(--success) !important; border-color: var(--success) !important; color: #fff !important;">
                        <i class="fa-solid fa-arrow-right me-1"></i> Listeyi Yönet
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Müşteriler Kartı -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 text-center p-4">
            <div class="card-body">
                <div class="bg-danger-subtle text-danger rounded-circle d-inline-flex align-items-center justify-content-center p-3 mb-3" style="width: 64px; height: 64px;">
                    <i class="fa-solid fa-users fa-2x"></i>
                </div>
                <h4 class="card-title text-dark fw-bold mb-2">Müşteriler</h4>
                <h1 class="display-5 fw-extrabold text-dark mb-2">@Model.MusteriSayisi</h1>
                <p class="text-muted small mb-4">Toplam kayıtlı müşteri portföyü</p>
                <div class="d-grid">
                    <a href="/Musteriler/Index" class="btn btn-danger shadow-sm" style="background-color: var(--danger) !important; border-color: var(--danger) !important; color: #fff !important;">
                        <i class="fa-solid fa-arrow-right me-1"></i> Listeyi Yönet
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>