@model WebProject.ViewModels.RegisterViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>Kayıt Ol - Medya Panel</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body style="display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; background-image: radial-gradient(circle at 50% 50%, #1e1b4b 0%, #060814 100%);">

    <div class="card" style="width: 100%; max-width: 450px; padding: 40px; box-shadow: 0 20px 50px rgba(0,0,0,0.6); border-top: 4px solid var(--primary);">
        <h2 style="color: var(--primary); text-align: center; margin: 0 0 10px 0; font-weight: 800; letter-spacing: 0.05em; text-shadow: 0 0 15px rgba(229, 9, 20, 0.4);">🎬 KAYIT OL</h2>
        <p style="text-align: center; color: var(--muted); font-size: 14px; margin-bottom: 30px;">Yeni hesap oluşturun</p>

        <form asp-action="Register" method="post">
            <div asp-validation-summary="ModelOnly" class="alert-danger-custom" style="padding: 10px; margin-bottom: 20px;"></div>

            <div style="margin-bottom: 18px;">
                <label asp-for="Name" style="font-weight: 600; font-size: 13px;">Ad Soyad</label>
                <input asp-for="Name" class="input" placeholder="Adınız ve soyadınız..." required />
                <span asp-validation-for="Name" style="color: var(--red); font-size: 12px;"></span>
            </div>

            <div style="margin-bottom: 18px;">
                <label asp-for="Email" style="font-weight: 600; font-size: 13px;">E-Posta</label>
                <input asp-for="Email" class="input" placeholder="E-posta adresiniz..." required />
                <span asp-validation-for="Email" style="color: var(--red); font-size: 12px;"></span>
            </div>

            <div style="margin-bottom: 18px;">
                <label asp-for="Password" style="font-weight: 600; font-size: 13px;">Parola</label>
                <input asp-for="Password" class="input" placeholder="Parolanız..." required />
                <span asp-validation-for="Password" style="color: var(--red); font-size: 12px;"></span>
            </div>

            <div style="margin-bottom: 25px;">
                <label asp-for="ConfirmPassword" style="font-weight: 600; font-size: 13px;">Parola Tekrarı</label>
                <input asp-for="ConfirmPassword" class="input" placeholder="Parolanızı tekrar giriniz..." required />
                <span asp-validation-for="ConfirmPassword" style="color: var(--red); font-size: 12px;"></span>
            </div>

            <button type="submit" class="btn btn-create" style="width: 100%; padding: 14px; font-size: 15px;">Kayıt Ol</button>
        </form>

        <div style="margin-top: 30px; text-align: center; font-size: 13px; color: var(--muted);">
            Zaten hesabınız var mı? <a href="/Account/Login" style="color: var(--accent); text-decoration: none; font-weight: 600;">Giriş Yapın</a>
        </div>
    </div>

</body>
</html>
