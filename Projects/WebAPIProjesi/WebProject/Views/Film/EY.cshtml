@model WebProject.Models.Film

<div class="card" style="max-width: 600px; margin: 0 auto;">
    <h2>@(Model.FilmId == 0 ? "➕ Yeni Film Ekle" : "📝 Film Düzenle")</h2>
    <hr style="border-color: rgba(255,255,255,0.05); margin: 15px 0;" />

    <form asp-action="EY" method="post">
        <input type="hidden" asp-for="FilmId" />

        <div style="margin-bottom: 15px;">
            <label asp-for="FilmAd" style="font-weight: 600;">Film Adı</label>
            <input type="text" asp-for="FilmAd" class="input" required placeholder="Film adını giriniz..." />
        </div>

        <div style="margin-bottom: 15px;">
            <label asp-for="Tur" style="font-weight: 600;">Tür</label>
            <input type="text" asp-for="Tur" class="input" required placeholder="Aksiyon, Komedi, Dram vb..." />
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 15px;">
            <div>
                <label asp-for="Sure" style="font-weight: 600;">Süre (Dakika)</label>
                <input type="number" asp-for="Sure" class="input" required min="1" placeholder="Sure (dk)..." />
            </div>
            <div>
                <label asp-for="YapimYili" style="font-weight: 600;">Yapım Yılı</label>
                <input type="number" asp-for="YapimYili" class="input" required min="1800" max="@DateTime.Now.Year" placeholder="Yapım Yılı..." />
            </div>
        </div>

        <div style="display: flex; gap: 10px; margin-top: 20px;">
            <button type="submit" class="btn btn-create">Kaydet</button>
            <a asp-action="Index" class="btn btn-gray">Vazgeç</a>
        </div>
    </form>
</div>
