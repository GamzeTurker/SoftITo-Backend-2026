@{
    ViewData["Title"] = "Ana Sayfa";
}

<!-- HERO BANNER -->
<div class="hero-banner">
    <div class="hero-content">
        <div style="background: var(--primary); display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 15px;">Öne Çıkan Yapım</div>
        <h1>Babam ve Oğlum</h1>
        <p>Ege'deki bir çiftlikten İstanbul'a, gazetecilik okumak için giden Sadık'ın, yıllar sonra oğlu Deniz ile birlikte baba evine dönüşünün hüzünlü ve unutulmaz hikayesi.</p>
        <div style="display: flex; gap: 15px;">
            <a href="/Film/Index" class="btn btn-create">🎬 Keşfet</a>
            <a href="/Dizi/Index" class="btn btn-gray">📺 Dizilere Bak</a>
        </div>
    </div>
</div>

<h2>📊 Medya Kütüphanesi Özet Bilgileri</h2>

<div class="grid-3" style="margin-top: 20px;">
    <!-- Filmler -->
    <div class="report-stat-card">
        <div class="report-icon" style="color: var(--accent); background: rgba(56, 189, 248, 0.08);">🎬</div>
        <div class="report-stat-info">
            <h3>Filmler</h3>
            <p>@ViewBag.FilmCount Başlık</p>
            <a href="/Film/Index" style="font-size: 12px; color: var(--accent); text-decoration: none; display: block; margin-top: 5px; font-weight: 600;">İncele &rarr;</a>
        </div>
    </div>

    <!-- Diziler -->
    <div class="report-stat-card">
        <div class="report-icon" style="color: var(--orange); background: rgba(249, 115, 22, 0.08);">📺</div>
        <div class="report-stat-info">
            <h3>Diziler</h3>
            <p>@ViewBag.DiziCount Başlık</p>
            <a href="/Dizi/Index" style="font-size: 12px; color: var(--orange); text-decoration: none; display: block; margin-top: 5px; font-weight: 600;">İncele &rarr;</a>
        </div>
    </div>

    <!-- Çizgi Filmler -->
    <div class="report-stat-card">
        <div class="report-icon" style="color: var(--purple); background: rgba(168, 85, 247, 0.08);">🧸</div>
        <div class="report-stat-info">
            <h3>Çizgi Filmler</h3>
            <p>@ViewBag.CFilmCount Başlık</p>
            <a href="/CizgiFilm/Index" style="font-size: 12px; color: var(--purple); text-decoration: none; display: block; margin-top: 5px; font-weight: 600;">İncele &rarr;</a>
        </div>
    </div>
</div>

<div class="card" style="margin-top: 20px; background: rgba(13, 18, 44, 0.4);">
    <h3>🚀 Platform Durumu</h3>
    <hr style="border-color: rgba(255,255,255,0.05); margin: 15px 0;" />
    <p style="color: var(--muted); line-height: 1.6; margin: 0;">Medya veritabanı aktif ve API üzerinden entegre edildi. Tüm listeleme, arama ve CRUD işlemleri başarıyla çalışmaktadır. Raporlama sistemimiz excel ve pdf formatlarında çıktı vermeye hazırdır.</p>
</div>
