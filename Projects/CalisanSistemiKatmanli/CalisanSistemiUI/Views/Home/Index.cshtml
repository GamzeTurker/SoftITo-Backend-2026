@{
    ViewData["Title"] = "Yönetici Paneli";
}

<div class="row mb-4">
    <div class="col-12">
        <div class="card bg-primary text-white border-0 shadow-sm overflow-hidden" style="position: relative;">
            <div class="card-body p-4 p-md-5">
                <div class="row align-items-center">
                    <div class="col-lg-8">
                        <h1 class="fw-bold mb-2">Hoş Geldiniz, Gamze Türker</h1>
                        <p class="mb-0 opacity-75">Bugün şirketinizde her şey yolunda görünüyor. Aşağıdan güncel operasyonel istatistikleri ve bekleyen görevleri inceleyebilirsiniz.</p>
                    </div>
                    <div class="col-lg-4 text-lg-end d-none d-lg-block">
                        <i class="fa-solid fa-face-smile fa-5x opacity-25"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- İSTATİSTİK KARTLARI -->
<div class="row g-4 mb-4">
    <!-- Personel Kartı -->
    <div class="col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="bg-primary-subtle text-primary rounded-3 p-3 me-3">
                    <i class="fa-solid fa-user-tie fa-2x"></i>
                </div>
                <div>
                    <span class="text-muted d-block fw-medium mb-1">Toplam Personel</span>
                    <h3 class="fw-bold text-dark mb-0">@ViewBag.TotalPersonel</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Departman Kartı -->
    <div class="col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="bg-success-subtle text-success rounded-3 p-3 me-3">
                    <i class="fa-solid fa-sitemap fa-2x"></i>
                </div>
                <div>
                    <span class="text-muted d-block fw-medium mb-1">Departmanlar</span>
                    <h3 class="fw-bold text-dark mb-0">@ViewBag.TotalDepartman</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Tamamlanan Görev Kartı -->
    <div class="col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="bg-info-subtle text-info rounded-3 p-3 me-3">
                    <i class="fa-solid fa-circle-check fa-2x"></i>
                </div>
                <div>
                    <span class="text-muted d-block fw-medium mb-1">Tamamlanan Görev</span>
                    <h3 class="fw-bold text-dark mb-0">@ViewBag.CompletedGorev</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Bekleyen Görev Kartı -->
    <div class="col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="bg-danger-subtle text-danger rounded-3 p-3 me-3">
                    <i class="fa-solid fa-clock fa-2x"></i>
                </div>
                <div>
                    <span class="text-muted d-block fw-medium mb-1">Bekleyen Görev</span>
                    <h3 class="fw-bold text-dark mb-0">@ViewBag.PendingGorev</h3>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- SON GÖREVLER -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-list-ul me-2 text-primary"></i>Son Eklenen Görevler</h5>
                <a asp-controller="Gorev" asp-action="Index" class="btn btn-link btn-sm text-primary text-decoration-none">Tümünü Gör</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Görev Tipi</th>
                                <th>Atanan Personel</th>
                                <th>Teslim Tarihi</th>
                                <th class="pe-3">Durum</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.RecentTasks == null || ((dynamic)ViewBag.RecentTasks).Count == 0)
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-4 text-muted">Kayıtlı görev bulunmamaktadır.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var task in ViewBag.RecentTasks)
                                {
                                    <tr>
                                        <td class="ps-3 fw-semibold">@task.GorevTipi</td>
                                        <td>@task.Personel</td>
                                        <td>@(task.SonTarih?.ToString("dd.MM.yyyy") ?? "-")</td>
                                        <td class="pe-3">
                                            @if (task.TamamlandiMi)
                                            {
                                                <span class="badge bg-success-subtle text-success rounded-pill px-3 py-1">Tamamlandı</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning-subtle text-warning rounded-pill px-3 py-1">Bekliyor</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- HIZLI EYLEMLER -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header">
                <h5 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-bolt me-2 text-warning"></i>Hızlı Eylemler</h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-3">
                    <a asp-controller="Personel" asp-action="Create" class="btn btn-outline-primary text-start d-flex align-items-center gap-3 p-3">
                        <i class="fa-solid fa-user-plus fa-lg"></i>
                        <div>
                            <span class="d-block fw-semibold" style="font-size: 14px;">Yeni Personel Ekle</span>
                            <small class="text-muted" style="font-size: 11px;">Sisteme yeni bir çalışan kaydedin</small>
                        </div>
                    </a>

                    <a asp-controller="Gorev" asp-action="Create" class="btn btn-outline-success text-start d-flex align-items-center gap-3 p-3">
                        <i class="fa-solid fa-circle-plus fa-lg"></i>
                        <div>
                            <span class="d-block fw-semibold" style="font-size: 14px;">Yeni Görev Tanımla</span>
                            <small class="text-muted" style="font-size: 11px;">Çalışanlara yeni bir iş ataması yapın</small>
                        </div>
                    </a>

                    <a asp-controller="Rapor" asp-action="Index" class="btn btn-outline-dark text-start d-flex align-items-center gap-3 p-3">
                        <i class="fa-solid fa-file-export fa-lg"></i>
                        <div>
                            <span class="d-block fw-semibold" style="font-size: 14px;">Raporlama Merkezi</span>
                            <small class="text-muted" style="font-size: 11px;">Excel ve PDF formatlarında rapor alın</small>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
