@model IEnumerable<CalisanSistemi.Model.Personel>



<div class="d-flex justify-content-between align-items-center mb-3">

    <h2 class="fw-bold">Personeller</h2>

    <a asp-action="Create" class="btn btn-success">
        + Yeni Personel
    </a>

</div>

<!-- ARAMA -->
<div class="card shadow-sm mb-3">
    <div class="card-body">

        <form method="get" asp-action="Index" class="row g-2">

            <div class="col-md-10">
                <input type="text"
                       name="search"
                       class="form-control"
                       placeholder="Ad, email veya meslek ara..." />
            </div>

            <div class="col-md-2 d-grid">
                <button class="btn btn-primary">Ara</button>
            </div>

        </form>

    </div>
</div>

<!-- TABLO -->
<div class="card shadow">

    <div class="card-body p-0">

        <table class="table table-hover mb-0">

            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Ad Soyad</th>
                    <th>Email</th>
                    <th>Yaş</th>
                    <th>Meslek</th>
                    <th>Maaş</th>
                    <th>Departman</th>
                    <th style="width:180px;">İşlemler</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.PersonelNo</td>
                        <td>@item.PersonelAdSoyad</td>
                        <td>@item.Email</td>
                        <td>@item.Yas</td>
                        <td>@item.Meslek</td>
                        <td>@item.Maas</td>
                        <td>@item.Departman?.DepartmanAdi</td>

                        <td>
                            <a asp-action="Edit"
                               asp-route-id="@item.PersonelNo"
                               class="btn btn-warning btn-sm">
                                Düzenle
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.PersonelNo"
                               class="btn btn-danger btn-sm">
                                Sil
                            </a>
                        </td>
                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

<div class="mt-3 text-muted">
    Toplam Personel: <strong>@Model.Count()</strong>
</div>