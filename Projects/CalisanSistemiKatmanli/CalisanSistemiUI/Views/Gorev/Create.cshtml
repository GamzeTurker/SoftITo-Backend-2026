@model CalisanSistemi.Model.Gorev

@{
    ViewData["Title"] = "Yeni Görev Ekle";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="d-flex align-items-center mb-3">
            <a asp-action="Index" class="btn btn-link text-secondary p-0 me-3"><i class="fa-solid fa-arrow-left fa-lg"></i></a>
            <h2 class="fw-bold text-dark mb-0">Yeni Görev Tanımla</h2>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <!-- Görev Seç -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Görev Tipi</label>
                        <select asp-for="GorevTipId" class="form-select shadow-none" asp-items="ViewBag.GorevTipi">
                            <option value="">Görev Tipi Seçiniz</option>
                        </select>
                        <span asp-validation-for="GorevTipId" class="text-danger small"></span>
                    </div>

                    <!-- Personel Seç -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Sorumlu Personel</label>
                        <select asp-for="PersonelNo" class="form-select shadow-none" asp-items="ViewBag.Personel">
                            <option value="">Personeli Seçiniz</option>
                        </select>
                        <span asp-validation-for="PersonelNo" class="text-danger small"></span>
                    </div>

                    <!-- Son Tarih -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Son Teslim Tarihi</label>
                        <input asp-for="SonTarih" type="date" class="form-control shadow-none" />
                        <span asp-validation-for="SonTarih" class="text-danger small"></span>
                    </div>

                    <!-- Durum (Checkbox) -->
                    <div class="form-check form-switch mb-4">
                        <input asp-for="TamamlandiMi" class="form-check-input" type="checkbox" role="switch" id="durumSwitch" />
                        <label class="form-check-label fw-semibold" for="durumSwitch">Görev Başlangıçta Tamamlandı Olarak İşaretlensin</label>
                    </div>

                    <!-- Butonlar -->
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success px-4 flex-grow-1">
                            <i class="fa-solid fa-floppy-disk me-1"></i> Görevi Kaydet
                        </button>
                        <a asp-action="Index" class="btn btn-light px-4 border">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
