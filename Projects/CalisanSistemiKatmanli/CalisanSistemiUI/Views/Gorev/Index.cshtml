@model IEnumerable<CalisanSistemi.Model.Gorev>

@{
    ViewData["Title"] = "Görevler";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-dark"><i class="fa-solid fa-list-check me-2 text-primary"></i>Görev Listesi</h2>
    <a asp-action="Create" class="btn btn-success shadow-sm">
        <i class="fa-solid fa-plus me-1"></i> Yeni Görev Ekle
    </a>
</div>

<!-- ARAMA PANELİ -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body bg-light rounded-3 p-3">
        <form method="get" class="row g-2 align-items-center">
            <div class="col-md-9 col-sm-8">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 text-muted">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </span>
                    <input type="text"
                           name="search"
                           class="form-control border-start-0 ps-0 shadow-none"
                           placeholder="Personel adı veya görev tipi ile arayın..." />
                </div>
            </div>
            <div class="col-md-3 col-sm-4 d-grid">
                <button class="btn btn-primary shadow-sm" type="submit">
                    <i class="fa-solid fa-filter me-1"></i> Listeyi Filtrele
                </button>
            </div>
        </form>
    </div>
</div>

<!-- GÖREV TABLOSU -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-striped mb-0 align-middle">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-3" style="width: 80px;">ID</th>
                        <th>Görev Adı / Tipi</th>
                        <th>Sorumlu Personel</th>
                        <th>Durum</th>
                        <th>Son Teslim Tarihi</th>
                        <th class="text-end pe-3" style="width: 200px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">
                                <i class="fa-solid fa-folder-open fa-2x mb-2 d-block text-secondary"></i>
                                Kayıtlı görev bulunmamaktadır.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-3 fw-bold text-secondary">#@item.GorevId</td>
                                <td class="fw-semibold text-dark">@item.GorevTipi?.Ad</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px; font-size: 13px;">
                                            @(item.Personel?.PersonelAdSoyad?.Substring(0, 1).ToUpper() ?? "P")
                                        </div>
                                        <div>
                                            <span class="d-block fw-medium text-dark">@item.Personel?.PersonelAdSoyad</span>
                                            <small class="text-muted" style="font-size: 11px;">@item.Personel?.Email</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @if (item.TamamlandiMi)
                                    {
                                        <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill"><i class="fa-solid fa-circle-check me-1"></i>Tamamlandı</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-subtle text-warning px-3 py-2 rounded-pill"><i class="fa-solid fa-clock me-1"></i>Devam Ediyor</span>
                                    }
                                </td>
                                <td>
                                    <span class="text-secondary"><i class="fa-regular fa-calendar me-1"></i>@(item.SonTarih?.ToString("dd.MM.yyyy") ?? "-")</span>
                                </td>
                                <td class="text-end pe-3">
                                    <a asp-action="Edit" asp-route-id="@item.GorevId" class="btn btn-outline-warning btn-sm me-1 px-3">
                                        <i class="fa-solid fa-pen-to-square"></i> Düzenle
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.GorevId" class="btn btn-outline-danger btn-sm px-3">
                                        <i class="fa-solid fa-trash"></i> Sil
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- İSTATİSTİKLER -->
<div class="mt-3 text-secondary d-flex justify-content-between align-items-center px-1">
    <span>Toplam Görev Sayısı: <strong class="text-dark">@Model.Count()</strong></span>
    <span>Tamamlanan: <strong class="text-success">@Model.Count(x => x.TamamlandiMi)</strong> | Devam Eden: <strong class="text-warning">@Model.Count(x => !x.TamamlandiMi)</strong></span>
</div>
