@model IEnumerable<EduCore.Models.Review>
@{
    ViewData["Title"] = "Değerlendirmelerim";
}

<div class="container" style="margin-top: 120px; margin-bottom: 60px;">
    <div class="mb-4">
        <span class="badge bg-soft text-info px-3 py-2 rounded-pill mb-2 fw-semibold" style="background: rgba(6, 182, 212, 0.1);">
            <i class="bi bi-chat-left-text-fill"></i> Geri Bildirimlerim
        </span>
        <h1 class="display-6 fw-bold text-dark mb-0">Değerlendirmelerim</h1>
        <p class="text-muted small">Kurslara yapmış olduğunuz yorumlar ve verdiğiniz puanlar.</p>
    </div>

    @if (TempData["success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-4 mb-4">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["success"]
        </div>
    }

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-md-6">
                    <div class="card edu-card border-0 shadow-sm rounded-4 p-4 position-relative">
                        <!-- Silme Butonu -->
                        <form method="post" asp-action="Delete" class="position-absolute top-0 end-0 m-3" onsubmit="return confirm('Bu yorumu silmek istiyor musunuz?');">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn btn-sm btn-link text-danger p-0" title="Sil">
                                <i class="bi bi-trash3-fill fs-5"></i>
                            </button>
                        </form>

                        <h5 class="fw-bold text-dark mb-2 pe-4">@item.Course.Title</h5>

                        <div class="d-flex align-items-center gap-2 mb-3">
                            <span class="text-warning">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="bi @(i <= item.Rating ? "bi-star-fill" : "bi-star")"></i>
                                }
                            </span>
                            <span class="small text-muted">(@item.Rating / 5)</span>
                        </div>

                        <p class="text-muted small bg-light p-3 rounded-3" style="line-height: 1.5;">@item.Comment</p>
                        <span class="text-muted small"><i class="bi bi-calendar3"></i> @item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="py-5 bg-white rounded-4 shadow-sm">
                    <i class="bi bi-chat-left-x fs-1 text-secondary opacity-50 mb-3 d-block"></i>
                    <h4 class="fw-bold text-dark">Henüz hiçbir kursu değerlendirmediniz.</h4>
                    <p class="text-muted">Kayıtlı olduğunuz kurslara ders odasından yorum yapabilirsiniz.</p>
                </div>
            </div>
        }
    </div>
</div>