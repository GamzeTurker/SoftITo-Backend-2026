@model IEnumerable<EduCore.Models.Certificate>
@{
    ViewData["Title"] = "Sertifikalarım";
}

<div class="container" style="margin-top: 120px; margin-bottom: 60px;">
    <div class="mb-4">
        <span class="badge bg-soft text-success px-3 py-2 rounded-pill mb-2 fw-semibold" style="background: rgba(6, 182, 212, 0.1);">
            <i class="bi bi-patch-check-fill"></i> Başarı Belgelerim
        </span>
        <h1 class="display-6 fw-bold text-dark mb-0">Sertifikalarım</h1>
        <p class="text-muted small">Eğitim tamamlama başarı sertifikalarınız.</p>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="card edu-card border-0 shadow-sm rounded-4 h-100 p-3">
                        <div class="rounded-3 overflow-hidden border mb-3" style="height: 180px;">
                            <img src="@item.CertificateImageUrl" class="w-100 h-100" style="object-fit: cover;" alt="Sertifika" />
                        </div>
                        <h5 class="fw-bold text-dark mb-2">@item.Enrollment.Course.Title</h5>
                        <span class="text-muted small d-block mb-3">Tarih: @item.IssuedAt.ToLocalTime().ToString("dd.MM.yyyy")</span>
                        <a href="@item.CertificateImageUrl" target="_blank" class="btn btn-outline-premium w-100 py-2 rounded-3">
                            <i class="bi bi-cloud-arrow-down-fill"></i> Sertifikayı İndir
                        </a>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="py-5 bg-white rounded-4 shadow-sm">
                    <i class="bi bi-award fs-1 text-secondary opacity-50 mb-3 d-block"></i>
                    <h4 class="fw-bold text-dark">Henüz sertifikanız bulunmuyor.</h4>
                    <p class="text-muted">Kayıtlı olduğunuz kursları tamamlayarak sertifika kazanabilirsiniz.</p>
                </div>
            </div>
        }
    </div>
</div>