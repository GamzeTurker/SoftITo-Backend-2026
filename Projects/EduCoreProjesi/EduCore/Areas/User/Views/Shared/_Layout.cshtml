@using System.Security.Claims
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EduCore Öğrenci Portalı</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light glass-nav fixed-top box-shadow py-3">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-area="User" asp-controller="Home" asp-action="Index">
                    <span class="fs-3 fw-bold text-dark">Edu<span style="color:#4f46e5">Core</span></span>
                    <span class="badge bg-soft text-primary ms-2 rounded-pill small" style="background: rgba(79, 70, 229, 0.1); font-size: 0.7rem; font-family: sans-serif;">Öğrenci Portalı</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <!-- Öğrenci Menü Seçenekleri -->
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-semibold px-3" asp-area="User" asp-controller="Home" asp-action="HomePage">Panelim</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-semibold px-3" asp-area="User" asp-controller="Enrollment" asp-action="Index">Kurslarım</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-semibold px-3" asp-area="User" asp-controller="Certificate" asp-action="Index">Sertifikalarım</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-semibold px-3" asp-area="User" asp-controller="Review" asp-action="Index">Değerlendirmelerim</a>
                        </li>
                    </ul>

                    <!-- Giriş / Çıkış ve Profil Yönetimi -->
                    <div class="d-flex align-items-center gap-2">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <div class="dropdown">
                                <button class="btn btn-light dropdown-toggle d-flex align-items-center gap-2 border-0 bg-transparent" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold" style="width: 36px; height: 36px; background: var(--primary-grad) !important;">
                                        @User.Identity.Name.Substring(0, 1).ToUpper()
                                    </div>
                                    <span class="fw-semibold text-dark small">@User.Identity.Name</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg mt-2">
                                    <li><a class="dropdown-item py-2" href="/Identity/Account/Manage"><i class="bi bi-person me-2"></i> Profil Bilgilerim</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form class="form-inline"  action="/Account/Logout"  method="post">
                                            <button type="submit" class="dropdown-item py-2 text-danger"><i class="bi bi-box-arrow-right me-2"></i> Çıkış Yap</button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a href="/Identity/Account/Login" class="btn btn-outline-premium">Giriş Yap</a>
                            <a href="/Identity/Account/Register" class="btn btn-premium">Kayıt Ol</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    <footer class="edu-footer mt-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 col-md-6">
                    <h5 class="fw-bold mb-3">Edu<span style="color:#06b6d4">Core</span></h5>
                    <p class="small">Kişiselleştirilmiş eğitim modelleri ve sertifikalı programlarımız ile hayalinizdeki kariyere giden yolda yanınızdayız.</p>
                </div>
                <div class="col-lg-2 col-md-6">
                    <h5 class="fw-bold mb-3">Hızlı Menü</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="#">Hakkımızda</a></li>
                        <li class="mb-2"><a href="/">Tüm Kurslar (Katalog)</a></li>
                        <li class="mb-2"><a href="#">Eğitmenlerimiz</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h5 class="fw-bold mb-3">Destek & İletişim</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="#">Sıkça Sorulan Sorular</a></li>
                        <li class="mb-2"><a href="#">İletişim Formu</a></li>
                        <li class="mb-2"><i class="bi bi-envelope"></i> info@educore.com</li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h5 class="fw-bold mb-3">Bültene Katılın</h5>
                    <div class="input-group">
                        <input type="email" class="form-control border-0" placeholder="E-posta adresiniz" />
                        <button class="btn btn-premium border-0" type="button">Katıl</button>
                    </div>
                </div>
            </div>
            <hr class="my-4 border-secondary" />
            <div class="d-flex justify-content-between align-items-center">
                <p class="small mb-0">&copy; @DateTime.Now.Year - EduCore. Tüm Hakları Saklıdır.</p>
                <div class="d-flex gap-3">
                    <a href="#"><i class="bi bi-facebook fs-5"></i></a>
                    <a href="#"><i class="bi bi-twitter-x fs-5"></i></a>
                    <a href="#"><i class="bi bi-linkedin fs-5"></i></a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>