@model EduCore.Models.Course
@{
    ViewData["Title"] = Model.Title;
    var lessons = (List<EduCore.Models.Lesson>)ViewBag.Lessons;
    var reviews = (List<EduCore.Models.Review>)ViewBag.Reviews;
    bool isEnrolled = ViewBag.IsEnrolled;
    int progressPercent = ViewBag.ProgressPercent;
}

<div class="container" style="margin-top: 130px; margin-bottom: 70px;">

    <!-- Bildirim Mesajları (Başarı/Hata) -->
    @if (TempData["success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-4 mb-4">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["success"]
        </div>
    }
    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm rounded-4 mb-4">
            <i class="bi bi-exclamation-octagon-fill me-2"></i> @TempData["error"]
        </div>
    }

    <div class="row g-4">

        <!-- SOL SÜTUN: Kurs Detayı, Ders Listesi ve Yorumlar -->
        <div class="col-lg-8">
            <!-- Kurs Bilgisi -->
            <div class="card edu-card border-0 shadow-sm rounded-4 p-4 mb-4">
                <span class="badge bg-soft text-primary px-3 py-2 rounded-pill mb-2 fw-semibold align-self-start" style="background: rgba(79, 70, 229, 0.1);">
                    <i class="bi bi-bookmark-star-fill"></i> Kurs Detayı
                </span>
                <h1 class="fw-bold text-dark mb-3">@Model.Title</h1>
                <p class="text-muted" style="line-height: 1.6; font-size: 1.05rem;">@Model.Description</p>
            </div>

            <!-- Ders Müfredatı (İçerik) -->
            <div class="card edu-card border-0 shadow-sm rounded-4 p-4 mb-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="fw-bold text-dark mb-0"><i class="bi bi-list-ol text-primary"></i> Ders Müfredatı</h4>
                    <span class="badge bg-light text-secondary border">Toplam @(lessons?.Count ?? 0) Ders</span>
                </div>
                <div class="list-group list-group-flush">
                    @if (lessons != null && lessons.Any())
                    {
                        foreach (var lesson in lessons)
                        {
                            <div class="list-group-item py-3 border-light d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center">
                                    <div class="rounded-circle p-2 me-3 d-flex align-items-center justify-content-center bg-light" style="width: 36px; height: 36px;">
                                        <span class="fw-bold text-secondary">@lesson.SortOrder</span>
                                    </div>
                                    <div>
                                        <span class="fw-semibold @(isEnrolled ? "text-dark" : "text-muted")">@lesson.Title</span>
                                        <span class="small text-muted d-block"><i class="bi bi-clock"></i> @lesson.DurationMinutes dk</span>
                                    </div>
                                </div>
                                <div>
                                    @if (isEnrolled)
                                    {
                                        <!-- Öğrenci kayıtlıysa doğrudan izleme odasındaki ilgili derse gider -->
                                        <a asp-area="User" asp-controller="Enrollment" asp-action="Watch" asp-route-id="@lesson.Id" class="btn btn-sm btn-premium py-1.5 px-3 rounded-pill">
                                            <i class="bi bi-play-fill"></i> İzle
                                        </a>
                                    }
                                    else
                                    {
                                        <!-- Kayıtlı değilse kilitli gösterilir -->
                                        <span class="badge bg-light text-muted border px-3 py-2 rounded-pill" style="font-size: 0.8rem;">
                                            <i class="bi bi-lock-fill me-1"></i> Kilitli
                                        </span>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted small mb-0">Bu kurs için henüz müfredat eklenmemiş.</p>
                    }
                </div>
            </div>

            <!-- YORUM EKLEME ALANI (Sadece Kursa Kayıtlı Olan Öğrencilere Gösterilir) -->
            @if (isEnrolled)
            {
                <div class="card edu-card border-0 shadow-sm rounded-4 p-4 mb-4">
                    <h4 class="fw-bold text-dark mb-3"><i class="bi bi-pencil-square text-success"></i> Kursu Değerlendir</h4>
                    <p class="text-muted small mb-3">Bu eğitim hakkındaki deneyimlerinizi ve puanınızı diğer öğrencilerle paylaşın.</p>

                    <form method="post" asp-area="User" asp-controller="Review" asp-action="Create">
                        <!-- Kurs ID'sini gizli gönderiyoruz -->
                        <input type="hidden" name="courseId" value="@Model.Id" />

                        <!-- Puan Seçimi (1-5 Yıldız) -->
                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary">Puanınız</label>
                            <select name="rating" class="form-select rounded-3">
                                <option value="5">⭐⭐⭐⭐⭐ (5 - Mükemmel)</option>
                                <option value="4">⭐⭐⭐⭐ (4 - Çok İyi)</option>
                                <option value="3">⭐⭐⭐ (3 - Orta)</option>
                                <option value="2">⭐⭐ (2 - Yetersiz)</option>
                                <option value="1">⭐ (1 - Çok Kötü)</option>
                            </select>
                        </div>

                        <!-- Yorum İçeriği -->
                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary">Yorumunuz</label>
                            <textarea name="comment" rows="3" class="form-control rounded-3" placeholder="Kurs hakkında neler düşünüyorsunuz? Neleri beğendiniz veya nelerin geliştirilmesi gerekiyor?" required></textarea>
                        </div>

                        <button type="submit" class="btn btn-premium px-4 py-2">
                            <i class="bi bi-send-fill"></i> Değerlendirmeyi Gönder
                        </button>
                    </form>
                </div>
            }

            <!-- Öğrenci Yorumları Listesi -->
            <div class="card edu-card border-0 shadow-sm rounded-4 p-4">
                <h4 class="fw-bold text-dark mb-4"><i class="bi bi-chat-left-text-fill text-info"></i> Öğrenci Değerlendirmeleri</h4>
                @if (reviews != null && reviews.Any())
                {
                    <div class="d-flex flex-column gap-3">
                        @foreach (var review in reviews)
                        {
                            <div class="p-3 bg-light rounded-4 border border-light">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <strong class="text-dark">@(review.Student?.Name ?? "Öğrenci")</strong>
                                    <span class="text-warning">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <i class="bi @(i <= review.Rating ? "bi-star-fill" : "bi-star")"></i>
                                        }
                                    </span>
                                </div>
                                <p class="mb-0 text-muted small" style="line-height: 1.5;">@review.Comment</p>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted small mb-0">Henüz değerlendirme yapılmamış.</p>
                }
            </div>
        </div>

        <!-- SAĞ SÜTUN: Kayıt Durumu & Fiyat Paneli -->
        <div class="col-lg-4">
            <div class="card edu-card border-0 shadow-lg rounded-4 overflow-hidden position-sticky" style="top: 110px;">
                <div class="ratio ratio-16x9">
                    @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
                    {
                        <img src="@Model.CoverImageUrl" class="w-100 h-100" style="object-fit: cover;" alt="Kurs Görseli" />
                    }
                    else
                    {
                        <div class="w-100 h-100 d-flex align-items-center justify-content-center text-white" style="background: linear-gradient(135deg, #4f46e5 0%, #06b6d4 100%);">
                            <i class="bi bi-journal-code display-4"></i>
                        </div>
                    }
                </div>

                <div class="card-body p-4">
                    <div class="mb-3">
                        <span class="text-muted small d-block">Kurs Ücreti</span>
                        <span class="fw-extrabold text-primary fs-3">@Model.Price.ToString("C2")</span>
                    </div>

                    <ul class="list-unstyled mb-4 text-muted small">
                        <li class="mb-2"><i class="bi bi-collection-play-fill text-primary me-2"></i> @(lessons?.Count ?? 0) Video Ders</li>
                        <li class="mb-2"><i class="bi bi-clock-history text-primary me-2"></i> Ömür Boyu Erişim</li>
                        <li class="mb-2"><i class="bi bi-award-fill text-primary me-2"></i> Resmi Sertifika</li>
                    </ul>

                    @if (isEnrolled)
                    {
                        <!-- Öğrenci Kayıtlı İse İlerleme Çubuğu ve Öğrenmeye Başla Butonu -->
                        <div class="mb-3">
                            <span class="small text-muted d-block mb-1">Kurs İlerleme Durumunuz: %@progressPercent</span>
                            <div class="progress rounded-pill" style="height: 8px;">
                                <div class="progress-bar bg-success" role="progressbar" style="width: @progressPercent%;"></div>
                            </div>
                        </div>

                        @if (lessons != null && lessons.Any())
                        {
                            <a asp-area="User" asp-controller="Enrollment" asp-action="Watch" asp-route-id="@lessons.First().Id" class="btn btn-success w-100 py-2.5 rounded-3 fw-bold">
                                <i class="bi bi-play-circle-fill"></i> Öğrenmeye Başla
                            </a>
                        }
                    }
                    else
                    {
                        <!-- Öğrenci Kayıtlı Değilse: Kaydolma Butonu (User/Home/Enroll action'ına POST eder) -->
                        <form method="post" asp-area="User" asp-controller="Home" asp-action="Enroll">
                            <input type="hidden" name="courseId" value="@Model.Id" />
                            <button type="submit" class="btn btn-premium w-100 py-2.5 rounded-3 fw-bold">
                                <i class="bi bi-bookmark-plus-fill"></i> Kursa Kaydol ve Başla
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>

    </div>
</div>