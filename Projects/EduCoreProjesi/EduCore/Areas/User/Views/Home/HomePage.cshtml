@model IEnumerable<EduCore.Models.Course>

@{
    ViewData["Title"] = "Eğitim Kataloğu";
}

<!-- Premium Yazı Tipleri ve İkonlar için Bağlantılar -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@600;700;800&family=Plus+Jakarta+Sans:wght@500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container" style="margin-top: 130px; margin-bottom: 70px;">

    <!-- Üst Başlık -->
    <div class="text-center mb-5">
        <span class="badge bg-soft text-primary px-3 py-2 rounded-pill mb-2 fw-semibold" style="background: rgba(79, 70, 229, 0.1);">
            <i class="bi bi-rocket-takeoff-fill"></i> Öğrenci Portalı
        </span>
        <h1 class="display-5 fw-bold text-dark">Eğitim Kataloğu</h1>
        <p class="text-muted">Kariyerinizi zirveye taşıyacak, özenle hazırlanmış ders programlarını keşfedin.</p>
    </div>

    <!-- Kategori Filtreleme Combo Box -->
    <div class="card edu-card shadow-sm border-0 rounded-4 p-4 mb-5" style="max-width: 600px; margin: 0 auto;">
        <form method="get" asp-area="User" asp-controller="Home" asp-action="Index">
            <div class="mb-0">
                <label for="categoryId" class="form-label fw-bold text-secondary mb-2">
                    <i class="bi bi-filter-square-fill me-1"></i> Kategoriye Göre Filtrele
                </label>
                <select id="categoryId" name="categoryId" asp-items="@ViewBag.CategoryList" class="form-select form-select-lg rounded-3 border-light shadow-sm" onchange="this.form.submit()" style="font-size: 1rem; cursor: pointer;">
                </select>
            </div>
        </form>
    </div>

    <!-- Bildirim Mesajları -->
    @if (TempData["success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-4 mb-4" role="alert" style="background: #ecfdf5; color: #065f46;">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["info"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show border-0 shadow-sm rounded-4 mb-4" role="alert" style="background: #eff6ff; color: #1e40af;">
            <i class="bi bi-info-circle-fill me-2"></i> @TempData["info"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Kurs Kartları Grid Yapısı -->
    <div class="row g-4 mt-2">
        @if (Model != null && Model.Any())
        {
            foreach (var course in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="card edu-card h-100 border-0 shadow-sm rounded-4 d-flex flex-column justify-content-between">

                        <!-- Kurs Görseli ve Kategori Rozeti -->
                        <div class="position-relative overflow-hidden" style="height: 200px;">
                            @if (!string.IsNullOrEmpty(course.CoverImageUrl))
                            {
                                <img src="@course.CoverImageUrl" class="w-100 h-100" style="object-fit: cover;" alt="@course.Title" />
                            }
                            else
                            {
                                <div class="w-100 h-100 d-flex align-items-center justify-content-center text-white" style="background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);">
                                    <i class="bi bi-journal-code display-4"></i>
                                </div>
                            }
                            <span class="position-absolute top-0 start-0 m-3 badge bg-dark text-white rounded-pill px-3 py-2 fs-7 shadow-sm">
                                @(course.Category?.Name ?? "Genel")
                            </span>
                        </div>

                        <!-- Kurs İçeriği -->
                        <div class="card-body p-4 d-flex flex-column flex-grow-1">
                            <h5 class="fw-bold text-dark mb-2 text-truncate-2" style="height: 50px; overflow: hidden;">@course.Title</h5>
                            <p class="text-muted small flex-grow-1 text-truncate-3" style="font-size: 0.9rem; line-height: 1.5; height: 60px; overflow: hidden;">
                                @course.Description
                            </p>

                            <hr class="my-3 text-light" />

                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <span class="text-muted small d-block">Kurs Ücreti</span>
                                    <span class="fw-extrabold text-primary fs-4">@course.Price.ToString("C2")</span>
                                </div>
                                <span class="small text-muted"><i class="bi bi-clock-fill me-1"></i> Ömür Boyu Erişim</span>
                            </div>
                        </div>

                        <!-- Kurs Detay ve Müfredat Sayfasına Geçiş Butonu -->
                        <div class="card-footer bg-transparent border-0 p-4 pt-0">
                            <a asp-area="User" asp-controller="Home" asp-action="Details" asp-route-id="@course.Id"
                               class="btn btn-premium w-100 py-2.5 rounded-3 d-flex align-items-center justify-content-center gap-2">
                                <i class="bi bi-info-circle-fill"></i> Detay ve Ders İçeriği
                            </a>
                        </div>

                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="py-5">
                    <i class="bi bi-journal-x fs-1 text-secondary opacity-50 mb-3 d-block"></i>
                    <h3 class="fw-bold text-dark">Bu kategoride henüz kurs bulunmuyor.</h3>
                    <p class="text-muted">Farklı bir kategori seçerek tekrar deneyebilirsiniz.</p>
                </div>
            </div>
        }
    </div>
</div>

<!-- ============================================== -->
<!-- HAREKETLİ KAREKODLU İNDİRİM KART BİLEŞENİ -->
<!-- ============================================== -->
@if (ViewBag.KareKodGorseli != null)
{
    <!-- 1. Kenarda Duran İnce Kart (Collapsed State) -->
    <div id="coupon-collapsed-card" class="coupon-collapsed" onclick="toggleCoupon(true)">
        <div class="coupon-collapsed-inner">
            <span class="gift-icon">🎁</span>
            <span class="collapsed-text">%10 İNDİRİMİNİ AL</span>
            <span class="arrow-indicator">➔</span>
        </div>
    </div>

    <!-- 2. Tıklanıldığında Açılan Detaylı Kart (Expanded State Overlay) -->
    <div id="coupon-overlay" class="coupon-overlay-container" onclick="toggleCoupon(false)">
        <div class="coupon-modal-card" onclick="event.stopPropagation()">
            <!-- Kapatma Butonu -->
            <button class="close-btn" onclick="toggleCoupon(false)">&times;</button>
            
            <!-- Kupon Bilet Tasarımı -->
            <div class="coupon-ticket">
                <div class="coupon-left">
                    <div class="coupon-badge">ÖĞRENCİYE ÖZEL KAMPANYA</div>
                    <h2 class="coupon-title">%10 İndirim Fırsatı</h2>
                    <p class="coupon-desc">EduCore platformunda alacağınız bir sonraki kursta geçerli %10 indirim kuponunuzu aktifleştirmek için yandaki karekodu telefonunuzla okutun!</p>
                    <div class="coupon-code-container">
                        <span class="coupon-code-label">KOD:</span>
                        <strong class="coupon-code-text">EDU10</strong>
                    </div>
                </div>
                
                <div class="coupon-divider"></div>
                
                <div class="coupon-right">
                    <div class="qr-wrapper">
                        <img src="@ViewBag.KareKodGorseli" alt="İndirim Karekodu" class="qr-image" />
                    </div>
                    <span class="qr-hint">Telefonla Tara</span>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .text-truncate-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .edu-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .edu-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.08) !important;
    }

    /* --- KAREKOD SIKIŞTIRILMIŞ YAN KART STİLİ (COLLAPSED STATE) --- */
    .coupon-collapsed {
        position: fixed;
        right: 0;
        top: 50%;
        transform: translateY(-50%);
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        color: white;
        padding: 20px 14px;
        border-radius: 20px 0 0 20px;
        cursor: pointer;
        box-shadow: -4px 4px 25px rgba(79, 70, 229, 0.4);
        z-index: 999;
        writing-mode: vertical-rl;
        text-orientation: mixed;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-right: none;
    }

    .coupon-collapsed:hover {
        padding-right: 24px;
        box-shadow: -6px 6px 30px rgba(79, 70, 229, 0.6);
        background: linear-gradient(135deg, #4f46e5, #4338ca);
    }

    .coupon-collapsed-inner {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .coupon-collapsed .gift-icon {
        font-size: 1.4rem;
        animation: qrGiftPulse 1.5s infinite alternate;
    }

    .coupon-collapsed .collapsed-text {
        font-weight: 800;
        font-size: 0.85rem;
        letter-spacing: 1.5px;
        font-family: 'Outfit', sans-serif;
    }

    .coupon-collapsed .arrow-indicator {
        font-size: 1rem;
        transform: rotate(90deg);
        margin-top: 5px;
    }

    /* --- AÇILAN MODAL ARKA PLANI (OVERLAY) --- */
    .coupon-overlay-container {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(15, 23, 42, 0.8);
        backdrop-filter: blur(10px);
        z-index: 10000;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.4s ease;
    }

    .coupon-overlay-container.active {
        opacity: 1;
        pointer-events: auto;
    }

    .coupon-modal-card {
        position: relative;
        max-width: 650px;
        width: 90%;
        transform: scale(0.85);
        transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .coupon-overlay-container.active .coupon-modal-card {
        transform: scale(1);
    }

    /* --- BİLET (TICKET) FORMUNDAKİ KART --- */
    .coupon-ticket {
        background: rgba(255, 255, 255, 0.98);
        border-radius: 28px;
        box-shadow: 0 30px 60px -15px rgba(0, 0, 0, 0.3);
        display: flex;
        overflow: hidden;
        position: relative;
        border: 1px solid rgba(255, 255, 255, 0.4);
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .coupon-left {
        padding: 40px;
        flex: 1.6;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .coupon-badge {
        background-color: rgba(99, 102, 241, 0.1);
        color: #4f46e5;
        font-size: 0.75rem;
        font-weight: 700;
        padding: 6px 14px;
        border-radius: 100px;
        width: fit-content;
        margin-bottom: 15px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .coupon-title {
        font-size: 2.3rem;
        font-weight: 800;
        color: #0f172a;
        margin: 0 0 12px 0;
        font-family: 'Outfit', sans-serif;
        background: linear-gradient(135deg, #1e1b4b, #4f46e5);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .coupon-desc {
        color: #475569;
        font-size: 0.95rem;
        line-height: 1.6;
        margin: 0 0 24px 0;
    }

    .coupon-code-container {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #f1f5f9;
        padding: 8px 18px;
        border-radius: 14px;
        width: fit-content;
        border: 2px dashed #cbd5e1;
    }

    .coupon-code-label {
        font-size: 0.8rem;
        color: #64748b;
        font-weight: 600;
    }

    .coupon-code-text {
        font-size: 1.2rem;
        color: #0f172a;
        font-weight: 800;
        letter-spacing: 1.5px;
    }

    /* Kuponun Ortasındaki Kesikli Ayrım Çizgisi */
    .coupon-divider {
        width: 2px;
        border-left: 2.5px dashed #cbd5e1;
        position: relative;
        background-color: transparent;
    }

    .coupon-divider::before,
    .coupon-divider::after {
        content: '';
        position: absolute;
        width: 24px;
        height: 24px;
        background-color: #0f172a;
        border-radius: 50%;
        left: -13px;
    }

    .coupon-divider::before { top: -12px; }
    .coupon-divider::after { bottom: -12px; }

    .coupon-right {
        padding: 40px;
        flex: 1;
        background: linear-gradient(135deg, #f8fafc, #f1f5f9);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    .qr-wrapper {
        background: white;
        padding: 14px;
        border-radius: 20px;
        box-shadow: 0 10px 20px -5px rgba(0, 0, 0, 0.1);
        margin-bottom: 14px;
        transition: transform 0.3s ease;
    }

    .qr-wrapper:hover {
        transform: scale(1.06);
    }

    .qr-image {
        width: 140px;
        height: 140px;
        display: block;
    }

    .qr-hint {
        font-size: 0.8rem;
        color: #4f46e5;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* Kapatma Butonu (×) */
    .close-btn {
        position: absolute;
        top: -45px;
        right: 0;
        background: transparent;
        border: none;
        color: white;
        font-size: 2.5rem;
        cursor: pointer;
        transition: transform 0.2s ease;
    }

    .close-btn:hover {
        transform: rotate(90deg);
    }

    /* Pulse Animasyonu */
    @@keyframes qrGiftPulse {
        0% { transform: scale(1); }
        100% { transform: scale(1.18); }
    }

    /* Mobil Cihazlar için Düzenlemeler */
    @@media (max-width: 600px) {
        .coupon-ticket {
            flex-direction: column;
        }
        .coupon-divider {
            width: 100%;
            height: 2px;
            border-top: 2.5px dashed #cbd5e1;
            border-left: none;
            margin: 10px 0;
        }
        .coupon-divider::before,
        .coupon-divider::after {
            top: -13px;
            left: auto;
        }
        .coupon-divider::before { left: -12px; }
        .coupon-divider::after { right: -12px; }
        .coupon-right {
            background: linear-gradient(180deg, #f8fafc, #f1f5f9);
            padding: 30px;
        }
    }
</style>

<script>
    function toggleCoupon(show) {
        const overlay = document.getElementById('coupon-overlay');
        if (show) {
            overlay.classList.add('active');
        } else {
            overlay.classList.remove('active');
        }
    }
</script>