@model EduCore.Models.Lesson
@{
    var otherLessons = (List<EduCore.Models.Lesson>)ViewBag.OtherLessons;
    var enrollment = (EduCore.Models.Enrollment)ViewBag.CurrentEnrollment;
    ViewData["Title"] = Model.Title;
}

<div class="container" style="margin-top: 120px; margin-bottom: 60px;">
    <div class="mb-4">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary mb-3"><i class="bi bi-arrow-left"></i> Kurslarıma Dön</a>
        <h2 class="fw-bold text-dark">@Model.Course.Title</h2>
        <span class="badge bg-primary">Ders İzleme Odası</span>
    </div>

    <div class="row g-4">
        <!-- Ders Videosu -->
        <div class="col-lg-8">
            <div class="card edu-card p-4 border-0 shadow-sm rounded-4">
                <h4 class="fw-bold mb-3">@Model.Title</h4>
                <div class="ratio ratio-16x9 rounded-3 overflow-hidden border mb-3">
                    <iframe src="@Model.VideoUrl" allowfullscreen></iframe>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-muted small"><i class="bi bi-clock"></i> Ders Süresi: @Model.DurationMinutes Dakika</span>
                    <form method="post" asp-action="CompleteLesson">
                        <input type="hidden" name="lessonId" value="@Model.Id" />
                        <button type="submit" class="btn btn-success px-4 py-2 rounded-pill fw-bold">
                            Dersi Tamamla & İlerle <i class="bi bi-arrow-right-short"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Ders Listesi (Müfredat) -->
        <div class="col-lg-4">
            <div class="card edu-card p-4 border-0 shadow-sm rounded-4">
                <h4 class="fw-bold mb-3 text-dark"><i class="bi bi-list-ol"></i> Kurs Müfredatı</h4>
                <div class="list-group list-group-flush" style="max-height: 400px; overflow-y: auto;">
                    @foreach (var l in otherLessons)
                    {
                        <a asp-action="Watch" asp-route-id="@l.Id" class="list-group-item list-group-item-action py-3 border-light d-flex justify-content-between align-items-center @(l.Id == Model.Id ? "active text-white rounded-3 bg-primary" : "")">
                            <div>
                                <span class="small fw-semibold d-block">Sıra @l.SortOrder</span>
                                <span style="font-size: 0.9rem;">@l.Title</span>
                            </div>
                            <span class="badge rounded-pill bg-soft text-muted"><i class="bi bi-clock"></i> @l.DurationMinutes dk</span>
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>