@model IEnumerable<EduCore.Models.Enrollment>
@{
    ViewData["Title"] = "Kurslarım";
}

<div class="container" style="margin-top: 120px; margin-bottom: 60px;">
    <div class="mb-4">
        <span class="badge bg-soft text-primary px-3 py-2 rounded-pill mb-2 fw-semibold" style="background: rgba(79, 70, 229, 0.1);">
            <i class="bi bi-mortarboard-fill"></i> Öğrenci Portalı
        </span>
        <h1 class="display-6 fw-bold text-dark mb-0">Kurslarım</h1>
        <p class="text-muted small">Kayıtlı olduğunuz eğitimlerin listesi ve ilerleme durumunuz.</p>
    </div>

    @if (TempData["success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-4 mb-4">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["success"]
        </div>
    }

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="card edu-card border-0 shadow-sm rounded-4 h-100 d-flex flex-column justify-content-between">
                        <div class="position-relative overflow-hidden" style="height: 160px;">
                            @if (!string.IsNullOrEmpty(item.Course.CoverImageUrl))
                            {
                                <img src="@item.Course.CoverImageUrl" class="w-100 h-100" style="object-fit: cover;" alt="@item.Course.Title" />
                            }
                            else
                            {
                                <div class="w-100 h-100 d-flex align-items-center justify-content-center text-white" style="background: linear-gradient(135deg, #4f46e5 0%, #06b6d4 100%);">
                                    <i class="bi bi-journal-code display-4"></i>
                                </div>
                            }
                            <span class="position-absolute top-0 start-0 m-3 badge bg-dark text-white rounded-pill px-3 py-2 fs-7 shadow-sm">
                                @item.Course.Category?.Name
                            </span>
                        </div>
                        <div class="card-body p-4">
                            <h5 class="fw-bold text-dark mb-3 text-truncate">@item.Course.Title</h5>
                            <span class="text-muted small d-block mb-2">Kayıt Tarihi: @item.EnrolledAt.ToLocalTime().ToString("dd.MM.yyyy")</span>

                            <!-- İlerleme Çubuğu -->
                            <div class="progress rounded-pill mb-1" style="height: 10px;">
                                <div class="progress-bar bg-success rounded-pill" role="progressbar" style="width: @item.ProgressPercent%;" aria-valuenow="@item.ProgressPercent" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                            <span class="small text-muted fw-semibold">Tamamlama: %@item.ProgressPercent</span>
                        </div>
                        <div class="card-footer bg-transparent border-0 p-4 pt-0">
                            <!-- Eğer ilk ders varsa ona gitmek için ilk dersi getireceğiz. Yoksa doğrudan Watch yollarız -->
                            <div class="d-flex gap-2">
                                <a asp-controller="Home" asp-action="Details"  asp-route-id="@item.CourseId" class="btn btn-premium w-100 py-2 rounded-3 d-flex align-items-center justify-content-center gap-2">
                                    <i class="bi bi-play-fill"></i> Dersleri İzle
                                </a>
                                <form method="post" asp-action="Cancel" onsubmit="return confirm('Kayıt silinsin mi?');">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-outline-danger py-2 rounded-3">
                                        <i class="bi bi-trash-fill"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="py-5 bg-white rounded-4 shadow-sm">
                    <i class="bi bi-journal-x fs-1 text-secondary opacity-50 mb-3 d-block"></i>
                    <h4 class="fw-bold text-dark">Kayıtlı kurs bulunamadı.</h4>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-premium px-4 py-2 mt-2">Kataloğa Git</a>
                </div>
            </div>
        }
    </div>
</div>