@model EduCore.Models.ViewModels.LessonVM

@{
    ViewData["Title"] = "Ders Silme Onayı";
}

<div class="container" style="margin-top: 120px; margin-bottom: 60px;">

    <!-- Üst Başlık -->
    <div class="mb-4">
        <span class="badge bg-soft text-danger px-3 py-2 rounded-pill mb-2 fw-semibold" style="background: rgba(239, 68, 68, 0.1); color: #ef4444 !important;">
            <i class="bi bi-shield-lock-fill"></i> Yönetici Paneli
        </span>
        <h1 class="display-6 fw-bold text-dark mb-0">Ders Silme Onayı</h1>
        <p class="text-muted small">Bu dersi silmek istediğinize emin misiniz?</p>
    </div>

    <!-- Onay Kartı -->
    <div class="card edu-card shadow-sm border-danger border rounded-4 overflow-hidden p-4 p-md-5" style="max-width: 600px; background: #fff;">

        <div class="alert alert-danger border-0 rounded-3 mb-4" style="background: #fef2f2; color: #991b1b;">
            <div class="d-flex align-items-center">
                <i class="bi bi-exclamation-triangle-fill fs-4 me-3 text-danger"></i>
                <div>
                    <strong>Dikkat!</strong> Bu ders içeriğini silmek üzeresiniz. Bu dersi izleyen öğrencilerin ilerlemeleri etkilenebilir.
                </div>
            </div>
        </div>

        <!-- Ders Detayları -->
        <ul class="list-group list-group-flush mb-4">
            <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center border-0 border-bottom">
                <span class="text-secondary fw-semibold">Ders Başlığı</span>
                <span class="text-dark fw-bold">@Model.Lesson.Title</span>
            </li>
            <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center border-0 border-bottom">
                <span class="text-secondary fw-semibold">Süre</span>
                <span class="text-dark fw-bold">@Model.Lesson.DurationMinutes Dakika</span>
            </li>
            <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center border-0">
                <span class="text-secondary fw-semibold">Sıra</span>
                <span class="text-dark fw-bold">@Model.Lesson.SortOrder</span>
            </li>
        </ul>

        <!-- Silme Formu -->
        <form asp-controller="Lesson" asp-action="Delete" method="post">

            <input type="hidden" asp-for="Lesson.Id" />

            <div class="d-flex justify-content-start gap-3 pt-4 border-top">
                <button type="submit" class="btn btn-danger d-inline-flex align-items-center gap-1 shadow-sm" style="border-radius: 20px; font-size: 0.9rem; padding: 8px 24px; background-color: #ef4444; border-color: #ef4444;">
                    <i class="bi bi-trash3-fill"></i> Evet, Sil
                </button>
                <a asp-controller="Lesson" asp-action="Index" class="btn btn-outline-secondary d-inline-flex align-items-center gap-1" style="border-radius: 20px; font-size: 0.9rem; padding: 8px 24px; border-color: #cbd5e1;">
                    Vazgeç
                </a>
            </div>

        </form>

    </div>

</div>