@model EduCore.Models.Lesson

@{
    ViewData["Title"] = Model.Title + " - İzle";
    var otherLessons = ViewBag.OtherLessons as IEnumerable<EduCore.Models.Lesson>;

    // Video tipini (YouTube mu yoksa Yerel dosya mı) tespit edip ona göre url hazırlıyoruz
    bool isYouTube = false;
    string embedUrl = Model.VideoUrl;
    if (!string.IsNullOrEmpty(Model.VideoUrl))
    {
        if (Model.VideoUrl.Contains("youtube.com") || Model.VideoUrl.Contains("youtu.be"))
        {
            isYouTube = true;
            string videoId = "";
            if (Model.VideoUrl.Contains("v="))
            {
                videoId = Model.VideoUrl.Split("v=")[1].Split("&")[0];
            }
            else if (Model.VideoUrl.Contains("youtu.be/"))
            {
                videoId = Model.VideoUrl.Split("youtu.be/")[1].Split("?")[0];
            }
            embedUrl = $"https://www.youtube.com/embed/{videoId}";
        }
    }
}

<div class="container" style="margin-top: 120px; margin-bottom: 60px;">

    <!-- Üst Ekmek Kırıntısı (Breadcrumb) ve Kurs Adı -->
    <div class="mb-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Category" asp-action="Index" class="text-decoration-none">Kategoriler</a></li>
                <li class="breadcrumb-item">
                    <a asp-controller="Category" asp-action="Details" asp-route-id="@Model.Course?.CategoryId" class="text-decoration-none">
                        @Model.Course?.Title
                    </a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">@Model.Title</li>
            </ol>
        </nav>
        <h2 class="fw-bold text-dark mb-0">@Model.Title</h2>
        <span class="text-muted small"><i class="bi bi-clock me-1"></i> Ders Süresi: @Model.DurationMinutes dakika</span>
    </div>

    <!-- Oynatıcı ve Oynatma Listesi Grid Yapısı -->
    <div class="row g-4">
        
        <!-- Sol Taraf: Video Oynatıcı -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden" style="background: #000;">
                <div class="ratio ratio-16x9">
                    @if (isYouTube)
                    {
                        <!-- YouTube Embed Oynatıcı -->
                        <iframe src="@embedUrl" title="YouTube video player" frameborder="0" 
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
                                allowfullscreen></iframe>
                    }
                    else if (!string.IsNullOrEmpty(Model.VideoUrl))
                    {
                        <!-- Yerel MP4 / Yüklenen Video Oynatıcı -->
                        <video controls controlsList="nodownload" class="w-100 h-100" style="object-fit: contain;">
                            <source src="@Model.VideoUrl" type="video/mp4">
                            Tarayıcınız video oynatma özelliğini desteklemiyor.
                        </video>
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center text-white bg-dark">
                            <div class="text-center">
                                <i class="bi bi-exclamation-octagon fs-1 text-danger"></i>
                                <p class="mt-2">Bu derse ait video dosyası veya bağlantısı bulunamadı.</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
            
            <!-- Ders Detayı Altı Açıklama Kutusu -->
            <div class="card border-0 shadow-sm rounded-4 p-4 mt-4" style="background: #fff;">
                <h5 class="fw-bold text-dark mb-2">Ders Hakkında</h5>
                <p class="text-muted mb-0">Bu ders, <strong>@Model.Course?.Title</strong> eğitim programının müfredatında yer alan @Model.SortOrder. sıradaki derstir.</p>
            </div>
        </div>

        <!-- Sağ Taraf: Oynatma Listesi (Diğer Dersler) -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 p-4" style="background: #fff; max-height: 520px; overflow-y: auto;">
                <h5 class="fw-bold text-dark mb-3">
                    <i class="bi bi-list-play text-primary me-2"></i> Kurs Müfredatı
                </h5>
                
                <div class="list-group list-group-flush">
                    @if (otherLessons != null && otherLessons.Any())
                    {
                        foreach (var lesson in otherLessons)
                        {
                            <!-- Şu an izlenen dersi görsel olarak vurguluyoruz (active-lesson sınıfı) -->
                            var isActive = lesson.Id == Model.Id;
                            
                            <a asp-controller="Lesson" asp-action="Watch" asp-route-id="@lesson.Id" 
                               class="list-group-item list-group-item-action px-2 py-3 border-0 border-bottom d-flex align-items-center justify-content-between rounded-3 mb-1 @(isActive ? "active-lesson" : "")"
                               style="transition: all 0.2s ease;">
                                <div class="d-flex align-items-center">
                                    <span class="badge @(isActive ? "bg-primary text-white" : "bg-light text-secondary border") rounded-circle p-2 me-2 d-flex align-items-center justify-content-center" style="width: 28px; height: 28px;">
                                        @lesson.SortOrder
                                    </span>
                                    <div class="d-flex flex-column">
                                        <span class="fw-bold text-dark small" style="display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden;">
                                            @lesson.Title
                                        </span>
                                        <small class="text-muted" style="font-size: 0.75rem;"><i class="bi bi-clock"></i> @lesson.DurationMinutes dk</small>
                                    </div>
                                </div>
                                @if (isActive)
                                {
                                    <span class="badge bg-soft text-primary px-2 py-1 rounded-pill" style="background: rgba(79, 70, 229, 0.1); font-size: 0.7rem;">Şimdi İzleniyor</span>
                                }
                            </a>
                        }
                    }
                </div>
            </div>
        </div>

    </div>

</div>

<style>
    /* Oynatma listesi hover ve aktif ders animasyonları */
    .list-group-item-action:hover {
        background-color: rgba(79, 70, 229, 0.04) !important;
        transform: translateX(3px);
    }
    .active-lesson {
        background-color: rgba(79, 70, 229, 0.08) !important;
        border-left: 4px solid #4f46e5 !important;
    }
</style>