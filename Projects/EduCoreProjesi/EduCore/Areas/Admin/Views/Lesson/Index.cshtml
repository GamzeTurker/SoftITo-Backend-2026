@model IEnumerable<EduCore.Models.Lesson>

@{
    ViewData["Title"] = "Ders Yönetimi";
}

<div class="container" style="margin-top: 120px; margin-bottom: 60px;">

    <!-- Üst Başlık ve Yeni Ders Ekleme Butonu -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
        <div>
            <span class="badge bg-soft text-primary px-3 py-2 rounded-pill mb-2 fw-semibold" style="background: rgba(79, 70, 229, 0.1);">
                <i class="bi bi-shield-lock-fill"></i> Yönetici Paneli
            </span>
            <h1 class="display-6 fw-bold text-dark mb-0">Ders Yönetimi</h1>
            <p class="text-muted small mb-0">Eğitimlerinize ait ders içeriklerini ve videolarını buradan yönetebilirsiniz.</p>
        </div>
        <div>
            <a asp-controller="Lesson" asp-action="Crup" class="btn btn-premium shadow-sm px-4 py-2">
                <i class="bi bi-plus-lg"></i> Yeni Ders Ekle
            </a>
        </div>
    </div>

    <!-- Başarı Bildirimi -->
    @if (TempData["success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-4 mb-4" role="alert" style="background: #ecfdf5; color: #065f46;">
            <div class="d-flex align-items-center">
                <i class="bi bi-check-circle-fill fs-4 me-3 text-success"></i>
                <div>
                    <strong>İşlem Başarılı!</strong> @TempData["success"]
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Arama Çubuğu -->
    <div class="card border-0 shadow-sm rounded-4 mb-4" style="background: rgba(248, 250, 252, 0.8); border: 1px solid rgba(226, 232, 240, 0.8) !important;">
        <div class="card-body p-3">
            <form asp-controller="Lesson" asp-action="Index" method="get">
                <div class="row g-2 align-items-center">
                    <div class="col-md-9 col-lg-10">
                        <div class="input-group shadow-sm" style="border-radius: 20px; overflow: hidden;">
                            <span class="input-group-text bg-white border-end-0" style="border: 1px solid #cbd5e1; padding-left: 18px;">
                                <i class="bi bi-search text-muted"></i>
                            </span>
                            <input type="text"
                                   name="search"
                                   value="@ViewBag.Search"
                                   class="form-control border-start-0 ps-2"
                                   placeholder="Ders başlığı veya kurs adı ile ara..."
                                   style="border: 1px solid #cbd5e1; font-size: 0.95rem; height: 44px; outline: none; box-shadow: none;" />
                        </div>
                    </div>
                    <div class="col-md-3 col-lg-2">
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-premium w-100 shadow-sm d-flex align-items-center justify-content-center gap-2" style="border-radius: 20px; font-size: 0.9rem; height: 44px;">
                                <i class="bi bi-funnel-fill"></i> Filtrele
                            </button>
                            @if (!string.IsNullOrEmpty(ViewBag.Search))
                            {
                                <a asp-controller="Lesson" asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center justify-content-center border-1" title="Aramayı Temizle" style="border-radius: 20px; font-size: 0.9rem; height: 44px; width: 55px; border-color: #cbd5e1;">
                                    <i class="bi bi-x-lg text-muted"></i>
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Ders Tablosu -->
    <div class="edu-card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light border-0">
                    <tr class="text-secondary" style="font-size: 0.85rem; letter-spacing: 0.8px;">
                        <th class="py-3 ps-4" style="width: 35%;">DERS BAŞLIĞI</th>
                        <th class="py-3" style="width: 25%;">AİT OLDUĞU KURS</th>
                        <th class="py-3 text-center" style="width: 15%;">SÜRE</th>
                        <th class="py-3 text-center" style="width: 10%;">SIRA</th>
                        <th class="py-3 text-center pe-4" style="width: 15%;">İŞLEMLER</th>
                    </tr>
                </thead>
                <tbody class="border-0">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr style="transition: background-color 0.2s ease;">
                                <td class="py-3 ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle me-3 d-flex align-items-center justify-content-center" style="background: rgba(79, 70, 229, 0.08); width: 36px; height: 36px;">
                                            <i class="bi bi-play-btn-fill text-primary"></i>
                                        </div>
                                        <!-- Ders başlığına tıklandığında video izleme sayfasına gider -->
                                        <a asp-controller="Lesson" asp-action="Watch" asp-route-id="@item.Id" class="text-decoration-none fw-bold text-primary fs-6">
                                            @(item.Title ?? "Başlıksız Ders")
                                        </a>
                                    </div>
                                </td>
                                <td class="py-3 text-muted">
                                    @(item.Course != null ? item.Course.Title : "Kurs Tanımsız")
                                </td>
                                <td class="py-3 text-center text-dark fw-semibold">
                                    <i class="bi bi-clock me-1 text-secondary"></i> @item.DurationMinutes dk
                                </td>
                                <td class="py-3 text-center text-secondary">
                                    <span class="badge bg-light text-secondary border">@item.SortOrder</span>
                                </td>
                                <td class="py-3 text-center pe-4">
                                    <div class="d-flex justify-content-center gap-2">
                                        <!-- Dersi İzle/Önizle Butonu -->
                                        <a asp-controller="Lesson" asp-action="Watch" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-1" style="border-radius: 20px; font-size: 0.85rem; padding: 6px 16px;">
                                            <i class="bi bi-play-circle-fill"></i> İzle
                                        </a>
                                        <!-- Düzenle Butonu -->
                                        <a asp-controller="Lesson" asp-action="Crup" asp-route-id="@item.Id" class="btn btn-sm btn-outline-premium border-1 d-inline-flex align-items-center gap-1" style="border-radius: 20px; font-size: 0.85rem; padding: 6px 16px;">
                                            <i class="bi bi-pencil-square"></i> Düzenle
                                        </a>
                                        <!-- Sil Butonu -->
                                        <a asp-controller="Lesson" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger d-inline-flex align-items-center gap-1" style="border-radius: 20px; font-size: 0.85rem; padding: 6px 16px; border: 1px solid #ef4444; color: #ef4444; background: transparent; transition: all 0.2s ease;">
                                            <i class="bi bi-trash3-fill"></i> Sil
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <div class="py-5">
                                    <i class="bi bi-play-circle-fill fs-1 text-secondary opacity-50 mb-3 d-block"></i>
                                    <span class="fs-5 fw-bold text-dark">Kayıtlı ders bulunamadı.</span>
                                    <a asp-controller="Lesson" asp-action="Crup" class="btn btn-premium btn-sm mt-3 px-4 py-2">
                                        <i class="bi bi-plus-lg"></i> Hemen Oluştur
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .table tbody tr:hover {
        background-color: rgba(79, 70, 229, 0.02) !important;
    }

    .btn-outline-danger:hover {
        background-color: #ef4444 !important;
        color: #fff !important;
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.2);
    }
</style>