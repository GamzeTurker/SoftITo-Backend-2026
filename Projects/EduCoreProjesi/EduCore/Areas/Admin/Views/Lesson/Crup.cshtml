@model EduCore.Models.ViewModels.LessonVM

@{
    var isEdit = Model.Lesson.Id > 0;
    ViewData["Title"] = isEdit ? "Dersi Düzenle" : "Yeni Ders Ekle";
}

<div class="container" style="margin-top: 120px; margin-bottom: 60px;">

    <!-- Üst Başlık -->
    <div class="mb-4">
        <span class="badge bg-soft text-primary px-3 py-2 rounded-pill mb-2 fw-semibold" style="background: rgba(79, 70, 229, 0.1);">
            <i class="bi bi-shield-lock-fill"></i> Yönetici Paneli
        </span>
        <h1 class="display-6 fw-bold text-dark mb-0">@(isEdit ? "Dersi Düzenle" : "Yeni Ders Ekle")</h1>
        <p class="text-muted small">Kurs içeriğinizi zenginleştirmek için video dosyasını yükleyin ve ders detaylarını girin.</p>
    </div>

    <!-- Form Kartı -->
    <div class="card edu-card shadow-sm border-0 rounded-4 overflow-hidden p-4 p-md-5" style="max-width: 800px; background: #fff;">

        <!-- enctype eklendi -->
        <form asp-controller="Lesson" asp-action="Crup" method="post" enctype="multipart/form-data">

            <input type="hidden" asp-for="Lesson.Id" />
            <!-- Eski video yolunu formda saklıyoruz ki değişmezse kaybolmasın -->
            <input type="hidden" asp-for="Lesson.VideoUrl" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <!-- Ders Başlığı -->
            <div class="mb-4">
                <label asp-for="Lesson.Title" class="form-label fw-bold text-secondary" style="font-size: 0.9rem;">DERS BAŞLIĞI</label>
                <input asp-for="Lesson.Title" class="form-control px-3 py-2" placeholder="Örn: Değişkenler ve Veri Tipleri" style="border-radius: 12px; border: 1px solid #cbd5e1;" />
                <span asp-validation-for="Lesson.Title" class="text-danger small mt-1 d-block"></span>
            </div>

            <!-- Video Dosyası Seçme -->
            <div class="mb-4">
                <label class="form-label fw-bold text-secondary" style="font-size: 0.9rem;">DERS VİDEOSU (.MP4, .WEBM vb.)</label>

                @if (isEdit && !string.IsNullOrEmpty(Model.Lesson.VideoUrl))
                {
                    <div class="mb-2 small text-muted">
                        <i class="bi bi-file-earmark-play-fill text-primary"></i> Mevcut Video:
                        <a href="@Model.Lesson.VideoUrl" target="_blank" class="text-decoration-none fw-semibold">Videoyu İzle</a>
                    </div>
                }

                <input type="file" name="file" class="form-control px-3 py-2" accept="video/*" style="border-radius: 12px; border: 1px solid #cbd5e1;" />
                <span asp-validation-for="Lesson.VideoUrl" class="text-danger small mt-1 d-block"></span>
            </div>

            <!-- Kurs Seçimi (Dropdown) -->
            <div class="mb-4">
                <label asp-for="Lesson.CourseId" class="form-label fw-bold text-secondary" style="font-size: 0.9rem;">AİT OLDUĞU KURS</label>
                <select asp-for="Lesson.CourseId"
                        asp-items="Model.CourseList"
                        class="form-select px-3 py-2"
                        style="border-radius: 12px; border: 1px solid #cbd5e1; height: 42px;">
                    <option value="">-- Kurs Seçiniz --</option>
                </select>
                <span asp-validation-for="Lesson.CourseId" class="text-danger small mt-1 d-block"></span>
            </div>

            <div class="row">
                <!-- Ders Süresi -->
                <div class="col-md-6 mb-4">
                    <label asp-for="Lesson.DurationMinutes" class="form-label fw-bold text-secondary" style="font-size: 0.9rem;">DERS SÜRESİ (DAKİKA)</label>
                    <input asp-for="Lesson.DurationMinutes" type="number" class="form-control px-3 py-2" style="border-radius: 12px; border: 1px solid #cbd5e1;" />
                    <span asp-validation-for="Lesson.DurationMinutes" class="text-danger small mt-1 d-block"></span>
                </div>

                <!-- Sıralama Düzeni -->
                <div class="col-md-6 mb-4">
                    <label asp-for="Lesson.SortOrder" class="form-label fw-bold text-secondary" style="font-size: 0.9rem;">SIRA DÜZENİ</label>
                    <input asp-for="Lesson.SortOrder" type="number" class="form-control px-3 py-2" style="border-radius: 12px; border: 1px solid #cbd5e1;" />
                    <span asp-validation-for="Lesson.SortOrder" class="text-danger small mt-1 d-block"></span>
                </div>
            </div>

            <!-- Butonlar -->
            <div class="d-flex justify-content-start gap-3 mt-4 pt-3 border-top">
                <button type="submit" class="btn btn-premium shadow-sm px-5 py-2">
                    <i class="bi bi-save-fill me-1"></i> Kaydet
                </button>
                <a asp-controller="Lesson" asp-action="Index" class="btn btn-outline-secondary d-inline-flex align-items-center gap-1" style="border-radius: 20px; font-size: 0.9rem; padding: 8px 24px; border-color: #cbd5e1;">
                    Vazgeç
                </a>
            </div>

        </form>

    </div>

</div>