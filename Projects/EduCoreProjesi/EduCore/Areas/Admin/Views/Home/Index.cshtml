@{
    ViewData["Title"] = "Geleceğin Eğitim Platformu";
}

<!-- Hero (Karşılama) Bölümü -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <span class="badge bg-soft text-primary px-3 py-2 rounded-pill mb-3 font-semibold" style="background: rgba(79, 70, 229, 0.1);">
                    <i class="bi bi-stars"></i> Yeni Nesil Öğrenim Deneyimi
                </span>
                <h1 class="display-3 fw-bold text-dark lh-sm mb-3">
                    Geleceğin Eğitimini <br />
                    <span class="font-classic text-primary">Bugünden</span> Deneyimleyin.
                </h1>
                <p class="lead text-muted mb-4 fs-5" style="max-width: 500px;">
                    EduCore ile sınırları kaldırın. Uzman eğitmenler eşliğinde, istediğiniz zaman ve istediğiniz yerde öğrenin.
                </p>
                <div class="d-flex gap-3">
                    <a href="#courses" class="btn btn-premium px-4 py-3 fs-6">Eğitime Başla</a>
                    <a href="#" class="btn btn-outline-premium px-4 py-3 fs-6"><i class="bi bi-play-circle-fill"></i> Tanıtım Videosu</a>
                </div>
            </div>
            <div class="col-lg-6 text-center position-relative">
                <!-- Tasarımın Arkasındaki Dekoratif Parlayan Çemberler -->
                <div class="position-absolute top-50 start-50 translate-middle rounded-circle bg-primary opacity-25 filter-blur" style="width: 300px; height: 300px; filter: blur(80px); z-index: 1;"></div>

                <!-- Eğitim Temsili Kartı -->
                <div class="edu-card p-4 mx-auto position-relative shadow-lg" style="max-width: 450px; z-index: 2; border: 1px solid rgba(255,255,255,0.8);">
                    <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=600&auto=format&fit=crop" class="img-fluid rounded-4 mb-3" alt="Akademi Öğrencileri" />
                    <div class="text-start">
                        <span class="badge bg-success mb-2">Popüler Kurs</span>
                        <h4 class="fw-bold">Modern Web Geliştirme Eğitimi</h4>
                        <p class="small text-muted mb-3">Sıfırdan ileri seviyeye React & .NET Core ile profesyonel bir kariyer inşa edin.</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-bold text-primary fs-5">₺499.00</span>
                            <span class="small text-muted"><i class="bi bi-clock"></i> 48 Saat İçerik</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- İstatistikler Bölümü -->
<section class="py-5" style="background-color: rgba(255, 255, 255, 0.4);">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-3 col-sm-6">
                <div class="stat-badge">
                    <div class="stat-number">10K+</div>
                    <div class="fw-semibold text-muted">Aktif Öğrenci</div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="stat-badge">
                    <div class="stat-number">150+</div>
                    <div class="fw-semibold text-muted">Nitelikli Kurs</div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="stat-badge">
                    <div class="stat-number">50+</div>
                    <div class="fw-semibold text-muted">Uzman Eğitmen</div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="stat-badge">
                    <div class="stat-number">%98</div>
                    <div class="fw-semibold text-muted">Memnuniyet Oranı</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Neden Biz? Özellikler Bölümü -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold">Öğrenme Yolculuğunuzu <span class="text-primary font-classic">Hızlandırın</span></h2>
            <p class="text-muted">Size en iyi deneyimi sunmak için tasarlanmış özelliklerimizi keşfedin.</p>
        </div>
        <div class="row g-4">
            <div class="col-lg-4 col-md-6">
                <div class="edu-card p-4 h-100">
                    <div class="fs-1 text-primary mb-3"><i class="bi bi-journal-bookmark-fill"></i></div>
                    <h4 class="fw-bold">Yapılandırılmış Dersler</h4>
                    <p class="text-muted">Öğrenim sürecini kolaylaştıracak adım adım hazırlanmış, sıralı video ders içerikleri.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="edu-card p-4 h-100">
                    <div class="fs-1 text-info mb-3"><i class="bi bi-patch-check-fill"></i></div>
                    <h4 class="fw-bold">Resmi Sertifikalar</h4>
                    <p class="text-muted">Kursları başarıyla tamamladığınızda kazandığınız, CV'nizi parlatacak doğrulabilir sertifikalar.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="edu-card p-4 h-100">
                    <div class="fs-1 text-warning mb-3"><i class="bi bi-chat-heart-fill"></i></div>
                    <h4 class="fw-bold">Topluluk Değerlendirmeleri</h4>
                    <p class="text-muted">Öğrencilerin yorumları ve puanlamaları sayesinde doğru kursu şeffaf bir şekilde seçme imkanı.</p>
                </div>
            </div>
        </div>
    </div>
</section>