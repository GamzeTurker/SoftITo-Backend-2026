@using System.Security.Claims
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EduCore Yönetici Portalı</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light glass-nav fixed-top box-shadow py-3">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-area="Admin" asp-controller="Home" asp-action="Index">
                    <span class="fs-3 fw-bold text-dark">Edu<span style="color:#4f46e5">Core</span></span>
                    <span class="badge bg-soft text-danger ms-2 rounded-pill small" style="background: rgba(220, 38, 38, 0.1); font-size: 0.7rem; font-family: sans-serif; color: #dc2626 !important;">Yönetici Paneli</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <!-- Admin Menü Seçenekleri -->
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-semibold px-3" asp-area="Admin" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-semibold px-3" asp-area="Admin" asp-controller="Course" asp-action="Index">Kurslar</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-semibold px-3" asp-area="Admin" asp-controller="Report" asp-action="Index">Raporlar</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark fw-semibold px-3" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Yönetim Paneli
                            </a>
                            <ul class="dropdown-menu border-0 shadow-lg mt-2">
                                <li><a class="dropdown-item py-2" asp-area="Admin" asp-controller="Category" asp-action="Index"><i class="bi bi-tags me-2"></i> Kategori Yönetimi</a></li>
                                <li><a class="dropdown-item py-2" asp-area="Admin" asp-controller="Course" asp-action="Index"><i class="bi bi-journal-code me-2"></i> Kurs Yönetimi</a></li>
                                <li><a class="dropdown-item py-2" asp-area="Admin" asp-controller="Lesson" asp-action="Index"><i class="bi bi-play-btn me-2"></i> Ders Yönetimi</a></li>
                            </ul>
                        </li>
                    </ul>

                    <!-- Giriş / Çıkış ve Yönetici Profil Yönetimi  -->
                    <div class="d-flex align-items-center gap-2">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <div class="dropdown">
                                <button class="btn btn-light dropdown-toggle d-flex align-items-center gap-2 border-0 bg-transparent" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <div class="rounded-circle bg-danger text-white d-flex align-items-center justify-content-center fw-bold" style="width: 36px; height: 36px; background: linear-gradient(135deg, #ef4444 0%, #b91c1c 100%) !important;">
                                        @User.Identity.Name.Substring(0, 1).ToUpper()
                                    </div>
                                    <span class="fw-semibold text-dark small">@User.Identity.Name</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg mt-2">
                                    <li><a class="dropdown-item py-2" href="/Identity/Account/Manage"><i class="bi bi-person me-2"></i> Profil Bilgilerim</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form class="form-inline" action="/Account/LogOut"
                                            method="post">
                                            <button type="submit" class="dropdown-item py-2 text-danger">
                                                <i class="bi bi-box-arrow-right me-2"></i> Çıkış Yap
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a href="/Identity/Account/Login" class="btn btn-outline-premium">Giriş Yap</a>
                            <a href="/Identity/Account/Register" class="btn btn-premium">Kayıt Ol</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    <footer class="edu-footer mt-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 col-md-6">
                    <h5 class="fw-bold mb-3">Edu<span style="color:#06b6d4">Core</span></h5>
                    <p class="small">Yönetici kontrol paneli ile eğitimleri, ders içeriklerini ve öğrenci geri bildirimlerini anlık olarak yönetebilirsiniz.</p>
                </div>
                <div class="col-lg-2 col-md-6">
                    <h5 class="fw-bold mb-3">Hızlı Menü</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a asp-area="Admin" asp-controller="Category" asp-action="Index">Kategoriler</a></li>
                        <li class="mb-2"><a asp-area="Admin" asp-controller="Course" asp-action="Index">Kurslar</a></li>
                        <li class="mb-2"><a asp-area="Admin" asp-controller="Lesson" asp-action="Index">Dersler</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h5 class="fw-bold mb-3">Destek & İletişim</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="#">Teknik Destek</a></li>
                        <li class="mb-2"><a href="#">Geliştirici İletişim</a></li>
                        <li class="mb-2"><i class="bi bi-envelope"></i> admin@educore.com</li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h5 class="fw-bold mb-3">Sistem Durumu</h5>
                    <span class="badge bg-success rounded-pill px-3 py-2"><i class="bi bi-check-circle me-1"></i> Tüm Sistemler Aktif</span>
                </div>
            </div>
            <hr class="my-4 border-secondary" />
            <div class="d-flex justify-content-between align-items-center">
                <p class="small mb-0">&copy; @DateTime.Now.Year - EduCore Yönetim Paneli. Tüm Hakları Saklıdır.</p>
                <div class="d-flex gap-3">
                    <a href="#"><i class="bi bi-facebook fs-5"></i></a>
                    <a href="#"><i class="bi bi-twitter-x fs-5"></i></a>
                    <a href="#"><i class="bi bi-linkedin fs-5"></i></a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>