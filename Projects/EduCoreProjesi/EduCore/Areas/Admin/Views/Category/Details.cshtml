@model IEnumerable<EduCore.Models.Course>

@{
    ViewData["Title"] = ViewBag.CategoryName + " Kursları";
}

<div class="container" style="margin-top: 120px; margin-bottom: 60px;">

    <!-- Üst Başlık ve Geri Dön Butonu -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-5">
        <div>
            <span class="badge bg-soft text-primary px-3 py-2 rounded-pill mb-2 fw-semibold" style="background: rgba(79, 70, 229, 0.1);">
                <i class="bi bi-folder2-open"></i> Kategori Detayı
            </span>
            <h1 class="display-6 fw-bold text-dark mb-0">@ViewBag.CategoryName Kategorisi</h1>
            <p class="text-muted small mb-0">Bu kategori altında yer alan tüm eğitim programları aşağıda listelenmiştir.</p>
        </div>
        <div>
            <a asp-controller="Category" asp-action="Index" class="btn btn-outline-secondary d-inline-flex align-items-center gap-1" style="border-radius: 20px; font-size: 0.9rem; padding: 8px 24px; border-color: #cbd5e1;">
                <i class="bi bi-arrow-left"></i> Kategorilere Dön
            </a>
        </div>
    </div>

    <!-- Kurs Kartları Grid Yapısı -->
    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card edu-card shadow-sm border-0 rounded-4 overflow-hidden h-100 d-flex flex-column" style="background: #fff; transition: transform 0.2s ease, box-shadow 0.2s ease;">
                        <!-- Kurs Görseli -->
                        <div style="height: 180px; overflow: hidden; background: rgba(79, 70, 229, 0.05);" class="position-relative">
                            @if (!string.IsNullOrEmpty(item.CoverImageUrl))
                            {
                                <img src="@item.CoverImageUrl" alt="@item.Title" style="width: 100%; height: 100%; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center h-100">
                                    <i class="bi bi-journal-bookmark-fill text-primary fs-1"></i>
                                </div>
                            }
                        </div>

                        <!-- Kart İçeriği -->
                        <div class="card-body p-4 d-flex flex-column flex-grow-1">
                            <h5 class="fw-bold text-dark mb-2">@item.Title</h5>
                            <p class="text-muted small flex-grow-1" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                                @item.Description
                            </p>
                            <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
                                <span class="fw-bold text-dark">
                                    @(item.Price == 0 ? "Ücretsiz" : $"{item.Price:N2} ₺")
                                </span>
                                <!-- Kursun detayına (yani derslerine) gitmek için link -->
                                <a asp-controller="Course" asp-action="Details" asp-route-id="@item.Id" class="btn btn-premium btn-sm px-4" style="border-radius: 15px;">
                                    Dersleri Gör <i class="bi bi-chevron-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-journal-x fs-1 text-muted opacity-50 mb-3 d-block"></i>
                <h4 class="text-dark fw-bold">Bu kategoride henüz kurs bulunmuyor.</h4>
                <p class="text-muted small">Yönetici panelinden bu kategoriye yeni kurslar atayabilirsiniz.</p>
            </div>
        }
    </div>

</div>

<style>
    .edu-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.08) !important;
    }
</style>