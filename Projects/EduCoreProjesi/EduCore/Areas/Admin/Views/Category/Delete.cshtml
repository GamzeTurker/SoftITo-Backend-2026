@model EduCore.Models.Category

@{
    ViewData["Title"] = "Kategoriyi Sil";
}

<div class="container d-flex justify-content-center align-items-center" style="margin-top: 130px; margin-bottom: 70px;">
    <!-- Sol tarafta kırmızı şerit ve tehlikeli bölge uyarısı -->
    <div class="card edu-card shadow-sm border-0 rounded-4 p-4 w-100" style="max-width: 600px; border-top: 5px solid #ef4444 !important;">
        <div class="mb-4">
            <span class="badge bg-soft text-danger px-3 py-2 rounded-pill mb-2 fw-semibold" style="background: rgba(239, 68, 68, 0.1);">
                <i class="bi bi-exclamation-triangle-fill"></i> Tehlikeli Bölge
            </span>
            <h2 class="fw-bold text-dark mb-0">Kategoriyi Sil</h2>
            <p class="text-muted small">Bu kategoriyi kalıcı olarak silmek üzeresiniz.</p>
        </div>

        <!-- Yumuşak Kırmızı Arka Planlı Uyarı Kutusu -->
        <div class="alert border-0 rounded-4 mb-4" style="background: #fef2f2; color: #991b1b;">
            <div class="d-flex">
                <i class="bi bi-exclamation-octagon-fill fs-4 me-3 text-danger"></i>
                <div>
                    <h6 class="fw-bold mb-1">Bu işlem geri alınamaz!</h6>
                    <p class="small mb-0">Bu kategoriyi sildiğinizde, ona bağlı olan tüm kurslar kategorisiz kalabilir. Lütfen silmeden önce bağlı kurs olmadığından emin olun.</p>
                </div>
            </div>
        </div>

        <form method="post" asp-action="Delete">
            <input asp-for="Id" type="hidden" />

            <!-- Kategori Adı (Sadece Okunabilir) -->
            <div class="mb-3">
                <label class="form-label fw-bold text-secondary">Kategori Adı</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 rounded-start-3"><i class="bi bi-tag-fill text-muted"></i></span>
                    <input asp-for="Name" class="form-control bg-white border-start-0 rounded-end-3 py-2" disabled style="font-size: 0.95rem;" />
                </div>
            </div>

            <!-- Kategori Açıklaması (Sadece Okunabilir) -->
            <div class="mb-4">
                <label class="form-label fw-bold text-secondary">Açıklama</label>
                <textarea asp-for="Description" rows="3" class="form-control bg-white rounded-3 py-2" disabled style="font-size: 0.95rem; resize: none;"></textarea>
            </div>

            <!-- Butonlar -->
            <div class="row pt-2 g-3">
                <div class="col-sm-6 order-2 order-sm-1">
                    <a asp-action="Index" class="btn btn-outline-premium w-100 py-2 d-flex align-items-center justify-content-center gap-2">
                        <i class="bi bi-arrow-left"></i> Vazgeç / Geri Dön
                    </a>
                </div>
                <div class="col-sm-6 order-1 order-sm-2">
                    <button type="submit" class="btn btn-danger w-100 py-2 d-flex align-items-center justify-content-center gap-2" style="border-radius: 30px; box-shadow: 0 4px 15px rgba(239, 68, 68, 0.3);">
                        <i class="bi bi-trash3-fill"></i> Evet, Kalıcı Olarak Sil
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>