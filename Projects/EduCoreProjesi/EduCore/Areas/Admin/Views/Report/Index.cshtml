@model object
@{
    ViewData["Title"] = "Sistem Raporları";
    int selectedReportId = ViewBag.SelectedReportId ?? 1;
}

<div class="container" style="margin-top: 130px; margin-bottom: 70px;">
    <!-- Üst Başlık -->
    <div class="text-center mb-5">
        <span class="badge bg-soft text-danger px-3 py-2 rounded-pill mb-2 fw-semibold" style="background: rgba(220, 38, 38, 0.1); color: #dc2626 !important;">
            <i class="bi bi-bar-chart-line-fill"></i> Yönetici Analizleri
        </span>
        <h1 class="display-5 fw-bold text-dark">Sistem Raporları</h1>
        <p class="text-muted">Platform genelindeki kurslar, kayıtlar, yorumlar ve finansal veriler için canlı SQL/LINQ raporları.</p>
    </div>

    <!-- Rapor Seçim Dropdown (Combo Box) -->
    <div class="card shadow-sm border-0 rounded-4 p-4 mb-5" style="max-width: 700px; margin: 0 auto; background: white;">
        <form method="get" asp-area="Admin" asp-controller="Report" asp-action="Index">
            <div>
                <label for="reportId" class="form-label fw-bold text-secondary mb-2">
                    <i class="bi bi-file-earmark-text-fill me-1"></i> Görüntülenecek Raporu Seçin
                </label>
                <select id="reportId" name="reportId" class="form-select form-select-lg rounded-3 border-light shadow-sm" onchange="this.form.submit()" style="font-size: 1rem; cursor: pointer;">
                    @foreach (var report in ViewBag.ReportList)
                    {
                        if (report.Id == selectedReportId)
                        {
                            <option value="@report.Id" selected>@report.Name</option>
                        }
                        else
                        {
                            <option value="@report.Id">@report.Name</option>
                        }
                    }
                </select>
            </div>
        </form>
    </div>

    <!-- Rapor Sonuçları Tablosu -->
    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="card-header bg-dark text-white p-4 border-0 d-flex justify-content-between align-items-center" style="background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%) !important;">
            <div>
                <h4 class="fw-bold mb-0">Rapor Çıktısı</h4>
                <small class="text-secondary" style="color: #94a3b8 !important;">Seçilen sorgunun anlık sonuç tablosu</small>
            </div>
            <span class="badge bg-primary rounded-pill px-3 py-2">
                <i class="bi bi-database me-1"></i> LINQ Veritabanı Sorgusu
            </span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                @if (selectedReportId == 1)
                {
                    var data = Model as List<EduCore.Areas.Admin.Controllers.ReportItem1>;
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Kurs ID</th>
                                <th>Kurs Başlığı</th>
                                <th>Kategori Adı</th>
                                <th>Kurs Fiyatı</th>
                                <th class="pe-4">Oluşturulma Tarihi</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (data != null && data.Any())
                            {
                                foreach (var item in data)
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold">#@item.CourseId</td>
                                        <td>@item.CourseTitle</td>
                                        <td><span class="badge bg-secondary rounded-pill">@item.CategoryName</span></td>
                                        <td class="fw-bold text-primary">@item.Price.ToString("C2")</td>
                                        <td class="pe-4">@item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">Kayıtlı veri bulunamadı.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else if (selectedReportId == 2)
                {
                    var data = Model as List<EduCore.Areas.Admin.Controllers.ReportItem2>;
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Kayıt ID</th>
                                <th>Öğrenci Adı</th>
                                <th>Kurs Başlığı</th>
                                <th>İlerleme Durumu</th>
                                <th class="pe-4">Kayıt Tarihi</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (data != null && data.Any())
                            {
                                foreach (var item in data)
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold">#@item.EnrollmentId</td>
                                        <td>@item.StudentName</td>
                                        <td>@item.CourseTitle</td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="progress flex-grow-1" style="height: 6px; width: 100px;">
                                                    <div class="progress-bar bg-success" role="progressbar" style="width: @item.ProgressPercent%" aria-valuenow="@item.ProgressPercent" aria-valuemin="0" aria-valuemax="100"></div>
                                                </div>
                                                <span class="fw-bold small">%@item.ProgressPercent</span>
                                            </div>
                                        </td>
                                        <td class="pe-4">@item.EnrolledAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">Kayıtlı veri bulunamadı.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else if (selectedReportId == 3)
                {
                    var data = Model as List<EduCore.Areas.Admin.Controllers.ReportItem3>;
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Yorum ID</th>
                                <th>Öğrenci Adı</th>
                                <th>Kurs Başlığı</th>
                                <th>Puan</th>
                                <th>Yorum İçeriği</th>
                                <th class="pe-4">Tarih</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (data != null && data.Any())
                            {
                                foreach (var item in data)
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold">#@item.ReviewId</td>
                                        <td>@item.StudentName</td>
                                        <td>@item.CourseTitle</td>
                                        <td>
                                            <span class="text-warning">
                                                @for (int i = 1; i <= 5; i++)
                                                {
                                                    if (i <= item.Rating)
                                                    {
                                                        <i class="bi bi-star-fill"></i>
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-star"></i>
                                                    }
                                                }
                                            </span>
                                        </td>
                                        <td class="text-muted text-truncate" style="max-width: 250px;">@item.Comment</td>
                                        <td class="pe-4">@item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-5 text-muted">Kayıtlı veri bulunamadı.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else if (selectedReportId == 4)
                {
                    var data = Model as List<EduCore.Areas.Admin.Controllers.ReportGroupByItem>;
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Kategori Adı</th>
                                <th>Kurs Adedi</th>
                                <th class="pe-4">Ortalama Fiyat</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (data != null && data.Any())
                            {
                                foreach (var item in data)
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold">@item.CategoryName</td>
                                        <td class="fw-semibold">@item.CourseCount adet</td>
                                        <td class="pe-4 fw-bold text-success">@item.AveragePrice.ToString("C2")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="text-center py-5 text-muted">Kayıtlı veri bulunamadı.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else if (selectedReportId == 5)
                {
                    var data = Model as List<EduCore.Areas.Admin.Controllers.ReportWhereItem1>;
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Kurs ID</th>
                                <th>Kurs Başlığı</th>
                                <th>Kurs Fiyatı</th>
                                <th class="pe-4">Oluşturulma Tarihi</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (data != null && data.Any())
                            {
                                foreach (var item in data)
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold">#@item.CourseId</td>
                                        <td>@item.CourseTitle</td>
                                        <td class="fw-bold text-danger">@item.Price.ToString("C2")</td>
                                        <td class="pe-4">@item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-5 text-muted">Fiyatı 150 TL altında olan bir kurs bulunmuyor.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else if (selectedReportId == 6)
                {
                    var data = Model as List<EduCore.Areas.Admin.Controllers.ReportWhereItem2>;
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Kayıt ID</th>
                                <th>Öğrenci Adı</th>
                                <th>Kurs Başlığı</th>
                                <th>Durum</th>
                                <th class="pe-4">Kayıt Tarihi</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (data != null && data.Any())
                            {
                                foreach (var item in data)
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold">#@item.EnrollmentId</td>
                                        <td class="fw-semibold">@item.StudentName</td>
                                        <td>@item.CourseTitle</td>
                                        <td><span class="badge bg-success px-3 py-2 rounded-pill"><i class="bi bi-patch-check-fill me-1"></i> Tamamlandı</span></td>
                                        <td class="pe-4">@item.EnrolledAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">Kursunu %100 tamamlayan öğrenci bulunmuyor.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .bg-soft {
        background-color: rgba(220, 38, 38, 0.1);
    }
    .table th {
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.5px;
        color: #475569;
        padding-top: 16px;
        padding-bottom: 16px;
    }
    .table td {
        padding-top: 16px;
        padding-bottom: 16px;
        color: #334155;
    }
</style>
