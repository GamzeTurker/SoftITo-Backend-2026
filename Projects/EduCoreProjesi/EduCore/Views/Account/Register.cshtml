@model EduCore.Models.ViewModels.RegisterViewModel
@{
    string roleName = ViewBag.Role;
    ViewData["Title"] = roleName == "Admin" ? "Yönetici Kayıt Formu" : "Öğrenci Kayıt Formu";
}

<div class="container d-flex justify-content-center align-items-center" style="margin-top: 130px; margin-bottom: 70px;">
    <div class="card edu-card shadow-sm border-0 rounded-4 p-4 w-100" style="max-width: 500px;">

        <div class="text-center mb-4">
            <!-- Seçilen role göre ikon ve renk değişir -->
            <div class="fs-1 @(roleName == "Admin" ? "text-info" : "text-primary") mb-2">
                <i class="@(roleName == "Admin" ? "bi bi-person-fill-gear" : "bi bi-person-plus-fill")"></i>
            </div>
            <h2 class="fw-bold text-dark mb-1">@ViewData["Title"]</h2>
            <p class="text-muted small">Eğitim portalına katılmak için bilgilerinizi eksiksiz doldurun.</p>
        </div>

        <!-- Form post edilirken seçilen rol bilgisini (asp-route-role) gönderir -->
        <form asp-action="Register" asp-route-role="@roleName" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold text-secondary"></label>
                <input asp-for="Name" class="form-control bg-light py-2" placeholder="Adınız Soyadınız" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-semibold text-secondary"></label>
                <input asp-for="Email" class="form-control bg-light py-2" placeholder="e-posta@adresiniz.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-semibold text-secondary"></label>
                <input asp-for="Password" class="form-control bg-light py-2" placeholder="Şifreniz (En az 6 karakter)" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label fw-semibold text-secondary"></label>
                <input asp-for="ConfirmPassword" class="form-control bg-light py-2" placeholder="Şifrenizi tekrar yazın" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-premium w-100 py-2.5 rounded-3 mb-3">
                Kayıt Ol
            </button>

            <!-- Giriş Yap butonuna basınca doğru role göre login sayfasına geri gönderir -->
            <p class="text-center text-muted small mb-0">
                Zaten üye misiniz? <a asp-action="Login" asp-route-role="@roleName" class="text-decoration-none fw-semibold">Giriş Yapın</a>
            </p>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}