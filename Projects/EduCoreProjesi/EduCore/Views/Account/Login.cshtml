@model EduCore.Models.ViewModels.LoginViewModel
@{
    string roleName = ViewBag.Role;
    ViewData["Title"] = roleName == "Admin" ? "Yönetici Girişi" : "Öğrenci Girişi";
}

<div class="container d-flex justify-content-center align-items-center" style="margin-top: 130px; margin-bottom: 70px;">
    <div class="card edu-card shadow-sm border-0 rounded-4 p-4 w-100" style="max-width: 450px;">

        <div class="text-center mb-4">
            <div class="fs-1 @(roleName == "Admin" ? "text-info" : "text-primary") mb-2">
                <i class="@(roleName == "Admin" ? "bi bi-shield-lock-fill" : "bi bi-mortarboard-fill")"></i>
            </div>
            <h2 class="fw-bold text-dark mb-1">@ViewData["Title"]</h2>
            <p class="text-muted small">Devam etmek için hesabınızla giriş yapın.</p>
        </div>

        @if (TempData["success"] != null)
        {
            <div class="alert alert-success border-0 small rounded-3 mb-3">
                <i class="bi bi-check-circle-fill"></i> @TempData["success"]
            </div>
        }

        <form asp-action="Login" asp-route-role="@roleName" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-semibold text-secondary"></label>
                <input asp-for="Email" class="form-control bg-light py-2" placeholder="e-posta@adresiniz.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <div class="d-flex justify-content-between">
                    <label asp-for="Password" class="form-label fw-semibold text-secondary"></label>
                    <a asp-action="VerifyEmail" class="small text-decoration-none">Şifremi Unuttum</a>
                </div>
                <input asp-for="Password" class="form-control bg-light py-2" placeholder="••••••" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="form-check mb-4">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label text-muted small"></label>
            </div>

            <button type="submit" class="btn btn-premium w-100 py-2.5 rounded-3 mb-3">
                Giriş Yap
            </button>

            @if (roleName == "Student")
            {
                <p class="text-center text-muted small mb-0">
                    Hesabınız yok mu? <a asp-action="Register" class="text-decoration-none fw-semibold">Kayıt Olun</a>
                </p>
            }

            <div class="text-center mt-3">
                <a asp-action="SelectRole" class="small text-muted text-decoration-none"><i class="bi bi-arrow-left"></i> Geri Dön</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}