@model EduCore.Models.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Yeni Şifre Oluştur";
}

<div class="container d-flex justify-content-center align-items-center" style="margin-top: 130px; margin-bottom: 70px;">
    <div class="card edu-card shadow-sm border-0 rounded-4 p-4 w-100" style="max-width: 450px;">

        <div class="text-center mb-4">
            <div class="fs-1 text-success mb-2">
                <i class="bi bi-key-fill"></i>
            </div>
            <h2 class="fw-bold text-dark mb-1">Yeni Şifre Belirle</h2>
            <p class="text-muted small">Lütfen yeni ve güvenli bir şifre girin.</p>
        </div>

        <form asp-action="ChangePassword" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <input asp-for="Email" type="hidden" />

            <div class="mb-3">
                <label class="form-label fw-semibold text-secondary">Doğrulanan Hesap</label>
                <input class="form-control bg-light" value="@Model.Email" disabled />
            </div>

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label fw-semibold text-secondary"></label>
                <input asp-for="NewPassword" class="form-control bg-light py-2" placeholder="Yeni Şifreniz" />
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmNewPassword" class="form-label fw-semibold text-secondary"></label>
                <input asp-for="ConfirmNewPassword" class="form-control bg-light py-2" placeholder="Yeni Şifreyi Onayla" />
                <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-premium w-100 py-2.5 rounded-3 mb-3">
                Şifreyi Güncelle
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}