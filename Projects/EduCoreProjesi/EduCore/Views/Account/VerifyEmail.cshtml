@model EduCore.Models.ViewModels.VerifyEmailViewModel
@{
    ViewData["Title"] = "Şifremi Sıfırla";
}

<div class="container d-flex justify-content-center align-items-center" style="margin-top: 130px; margin-bottom: 70px;">
    <div class="card edu-card shadow-sm border-0 rounded-4 p-4 w-100" style="max-width: 450px;">

        <div class="text-center mb-4">
            <div class="fs-1 text-warning mb-2">
                <i class="bi bi-shield-exclamation"></i>
            </div>
            <h2 class="fw-bold text-dark mb-1">Şifremi Unuttum</h2>
            <p class="text-muted small">Lütfen hesabınıza kayıtlı olan e-posta adresinizi girin.</p>
        </div>

        <form asp-action="VerifyEmail" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="mb-4">
                <label asp-for="Email" class="form-label fw-semibold text-secondary"></label>
                <input asp-for="Email" class="form-control bg-light py-2" placeholder="e-posta@adresiniz.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-premium w-100 py-2.5 rounded-3 mb-3">
                E-postayı Doğrula
            </button>

            <div class="text-center">
                <a asp-action="SelectRole" class="small text-muted text-decoration-none"><i class="bi bi-arrow-left"></i> Giriş Ekranına Dön</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}