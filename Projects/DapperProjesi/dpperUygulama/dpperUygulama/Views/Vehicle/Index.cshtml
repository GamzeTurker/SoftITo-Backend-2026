@model IEnumerable<dpperUygulama.Models.Vehicle>

<div class="card" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px;">
    <div>
        <h2 style="margin: 0 0 10px 0;">🚘 Araçlar</h2>
        <div style="display: flex; gap: 10px; flex-wrap: wrap;">
            <a href="/Vehicle/EY" class="btn btn-create">+ Yeni Araç</a>
            <a asp-action="ExportExcel" asp-route-searchText="@ViewBag.SearchText" class="btn btn-green">Excel'e Aktar</a>
            <a asp-action="ExportPdf" asp-route-searchText="@ViewBag.SearchText" class="btn btn-red">PDF'e Aktar</a>
        </div>
    </div>
    <form method="get" asp-action="Index" style="display: flex; gap: 10px; align-items: center;">
        <input type="text" name="searchText" value="@ViewBag.SearchText" class="input" placeholder="Araç Ara (Marka, Plaka...)" style="margin: 0; width: 250px;" />
        <button type="submit" class="btn btn-blue">Ara</button>
        @if (!string.IsNullOrEmpty(ViewBag.SearchText))
        {
            <a asp-action="Index" class="btn btn-gray">Temizle</a>
        }
    </form>
</div>

<div class="card">

    <table class="table-dark">
        <thead>
            <tr>
                <th>ID</th>
                <th>Marka</th>
                <th>Model</th>
                <th>Plaka</th>
                <th>Müşteri Adı</th>
                <th>İşlemler</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                var customer = ((List<dpperUygulama.Models.Customer>)ViewBag.Customers)
                    .FirstOrDefault(x => x.CustomerId == item.CustomerId);
                <tr>
                    <td>@item.VehicleId</td>
                    <td>@item.Brand</td>
                    <td>@item.Model</td>
                    <td>@item.Plate</td>
                    <td>@customer?.FullName</td>

                    <td>
                        <a asp-action="EY"
                           asp-route-id="@item.VehicleId"
                           class="btn btn-edit">
                            Düzenle
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.VehicleId"
                           class="btn btn-delete">
                            Sil
                        </a>
                    </td>
                </tr>
            }
        </tbody>

    </table>

</div>
 