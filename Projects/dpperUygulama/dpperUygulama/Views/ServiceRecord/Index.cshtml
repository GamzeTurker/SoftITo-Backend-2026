 @model IEnumerable<dpperUygulama.Models.ServiceRecord>

<div class="card" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px;">
    <div>
        <h2 style="margin: 0 0 10px 0;">🔧 Servis Kayıtları</h2>
        <div style="display: flex; gap: 10px; flex-wrap: wrap;">
            <a asp-action="EY" class="btn btn-create">+ Yeni Servis</a>
            <a asp-action="ExportExcel" asp-route-searchText="@ViewBag.SearchText" class="btn btn-green">Excel'e Aktar</a>
            <a asp-action="ExportPdf" asp-route-searchText="@ViewBag.SearchText" class="btn btn-red">PDF'e Aktar</a>
        </div>
    </div>
    <form method="get" asp-action="Index" style="display: flex; gap: 10px; align-items: center;">
        <input type="text" name="searchText" value="@ViewBag.SearchText" class="input" placeholder="Servis Ara (Marka, Usta...)" style="margin: 0; width: 250px;" />
        <button type="submit" class="btn btn-blue">Ara</button>
        @if (!string.IsNullOrEmpty(ViewBag.SearchText))
        {
            <a asp-action="Index" class="btn btn-gray">Temizle</a>
        }
    </form>
</div>

<div class="card">

<table class="table-dark">
    <thead>
        <tr>
            <th>Müşteri</th>
            <th>Araç</th>
            <th>Personel</th>
            <th>Tarih</th>
            <th>Açıklama</th>
            <th>Ücret</th>
            <th>İşlemler</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.FullName</td>
                <td>@item.Brand - @item.Plate</td>
                <td>@item.EmployeeName</td>
                <td>@item.ServiceDate.ToShortDateString()</td>
                <td>@item.Description</td>
                <td>@item.Cost ₺</td>
                <td>
                        <a asp-action="EY"
                           asp-route-id="@item.ServiceId"
                           class="btn btn-edit">
                            Düzenle
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.ServiceId"
                           class="btn btn-delete">
                            Sil
                        </a>
                </td>
            </tr>
        }
    </tbody>

</table>

</div>