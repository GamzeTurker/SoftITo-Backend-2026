@model IEnumerable<dpperUygulama.Models.Customer>

@{
    ViewData["Title"] = "Index";
}
<div class="card" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px;">
    <div>
        <h2 style="margin: 0 0 10px 0;">Müşteriler</h2>
        <a asp-action="EY" class="btn btn-create">Yeni Müşteri Ekle</a>
    </div>
    <form method="get" asp-action="Index" style="display: flex; gap: 10px; align-items: center;">
        <input type="text" name="searchText" value="@ViewBag.SearchText" class="input" placeholder="Müşteri Ara..." style="margin: 0; width: 250px;" />
        <button type="submit" class="btn btn-blue">Ara</button>
        @if (!string.IsNullOrEmpty(ViewBag.SearchText))
        {
            <a asp-action="Index" class="btn btn-gray">Temizle</a>
        }
    </form>
</div>

<div class="card">

<table class="table table-dark table-bordered ">
    <thead>
        <tr>
            <th>Müşteri No</th>
            <th>Ad Soyad</th>
            <th>Telefon</th>
            <th>Adres</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.CustomerId</td>
                <td>@item.FullName</td>
                <td>@item.Phone</td>
                <td>@item.Address</td>
                <td>
                    <a asp-action="EY"
                       asp-route-id="@item.CustomerId"
                       class="btn btn-edit">
                        Düzenle
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@item.CustomerId"
                       class="btn btn-delete"
                       onclick="return confirm('Silmek istediğinize emin misiniz?')">
                        Sil
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
</div>