@model IEnumerable<OkulNotSistemi.Models.Reports>

<h3>🏫 Sınıf Başarı Analiz Raporu</h3>

<table class="table table-hover table-bordered">
    <thead>
        <tr>
            <th>Ders</th>
            <th>Öğrenci</th>
            <th>Ortalama</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.DersAd</td>
                <td>@item.OgrenciAdSoyad</td>
                <td>@item.Ortalama.ToString()</td>
            </tr>
        }
    </tbody>
</table>