@model SiparisSistemi.Models.Musteriler
@{
    ViewData["Title"] = "Delete";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-6">

            <div class="card shadow border-danger">

                <!-- HEADER (BAŞLIK) -->
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">Müşteri Silme Onayı</h4>
                </div>

                <div class="card-body">

                    <!-- UYARI MESAJI -->
                    <div class="alert alert-warning">
                        ⚠ Bu müşteriyi silmek üzeresiniz. Bu işlem geri alınamaz.
                    </div>

                    <!-- MÜŞTERİ DETAYLARI -->
                    <ul class="list-group mb-3">

                        <li class="list-group-item">
                            <b>Müşteri ID:</b> @Model.MusteriId
                        </li>

                        <li class="list-group-item">
                            <b>Adı Soyadı:</b> @Model.MusteriAdSoyad
                        </li>

                        @*
                           Eğer Musteriler modelinizde Telefon, E-posta veya Adres gibi
                           başka alanlar da tanımlıysa, onları da aşağıdakine benzer şekilde ekleyebilirsiniz:

<li class="list-group-item">
                               <b>Telefon:</b> @Model.Telefon
                           </li>
                        *@

                    </ul>

                    <!-- SİLME FORMU -->
                    <form asp-action="Delete" method="post">

                        <!-- asp-for kullanımı sayesinde ID otomatik olarak form verilerine bağlanır -->
                        <input type="hidden" asp-for="MusteriId" />

                        <button type="submit" class="btn btn-danger w-100 mb-2">
                            Evet, Sil
                        </button>

                        <a asp-action="Index" class="btn btn-secondary w-100">
                            Vazgeç
                        </a>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>