@model IEnumerable<SiparisSistemi.Models.Report>
@{
    ViewData["Title"] = "Ürün Satış Analizi (Group By)";
}

<div class="container py-4">

    <div class="card shadow-sm border-0">

        <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Ürün Satış Analizi (Group By)</h4>
            <a asp-action="Index" class="btn btn-light btn-sm">Geri Dön</a>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-3">Ürün Adı</th>
                            <th>Toplam Satılan Adet</th>
                            <th class="pe-3">Elde Edilen Toplam Gelir</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-3 fw-bold">@item.UrunAdi</td>
                                <td>@item.ToplamSatisAdeti Adet</td>
                                <td class="pe-3 text-success fw-bold">@item.ToplamCiro.ToString("N2") ₺</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>

</div>