@model List<LibraryMVC.Models.Emanet>
@{
    ViewData["Title"] = "Emanet Kitap İşlemleri";
}

<div class="card card-custom p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-handshake text-primary me-2"></i> Emanet Kitap İşlemleri</h4>
        <a href="/Emanet/Create" class="btn btn-primary"><i class="fa-solid fa-plus me-1"></i> Yeni Emanet Ver</a>
    </div>

    <!-- ARAMA VE RAPORLAMA BARBARI -->
    <div class="row mb-3 g-2">
        <div class="col-md-6">
            <form method="get" action="/Emanet/Index" class="d-flex">
                <input type="text" name="search" class="form-control me-2" placeholder="Kitap başlığı, üye adı veya durum ara..." value="@ViewBag.Search" />
                <button type="submit" class="btn btn-outline-primary px-3">Ara</button>
                @if (!string.IsNullOrEmpty(ViewBag.Search))
                {
                    <a href="/Emanet/Index" class="btn btn-outline-secondary ms-1">Temizle</a>
                }
            </form>
        </div>
        <div class="col-md-6 text-md-end">
            <a href="/Emanet/ExportExcel?search=@ViewBag.Search" class="btn btn-success me-1"><i class="fa-solid fa-file-excel me-1"></i> Excel İndir</a>
            <a href="/Emanet/ExportPdf?search=@ViewBag.Search" class="btn btn-danger"><i class="fa-solid fa-file-pdf me-1"></i> PDF İndir</a>
        </div>
    </div>

    <!-- TABLO -->
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th style="width: 80px;">ID</th>
                    <th>Kitap Başlığı</th>
                    <th>Teslim Alan Üye</th>
                    <th>Emanet Tarihi</th>
                    <th>Teslim Tarihi</th>
                    <th>Durum</th>
                    <th style="width: 250px;" class="text-center">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td class="fw-semibold">@item.KitapBaslik</td>
                            <td>@item.UyeAdSoyad</td>
                            <td>@item.EmanetTarihi.ToString("dd.MM.yyyy")</td>
                            <td>@(item.TeslimTarihi?.ToString("dd.MM.yyyy") ?? "-")</td>
                            <td>
                                @if (item.Durum == "Emanette")
                                {
                                    <span class="badge bg-primary">Emanette</span>
                                }
                                else if (item.Durum == "Teslim Edildi")
                                {
                                    <span class="badge bg-success">Teslim Edildi</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Gecikmiş</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (item.Durum != "Teslim Edildi")
                                {
                                    <form action="/Emanet/ReturnBook/@item.Id" method="post" style="display:inline;">
                                        <button type="submit" class="btn btn-sm btn-success me-1"><i class="fa-solid fa-square-check"></i> Teslim Al</button>
                                    </form>
                                }
                                <a href="/Emanet/Edit/@item.Id" class="btn btn-sm btn-outline-warning me-1"><i class="fa-solid fa-edit"></i> Düzenle</a>
                                <form action="/Emanet/Delete/@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Bu işlemi silmek istediğinize emin misiniz?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i> Sil</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted">Emanet kitap kaydı bulunamadı.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
