@model LibraryMVC.Models.Emanet
@{
    ViewData["Title"] = "Yeni Emanet Kaydı";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card card-custom p-4">
            <h4 class="fw-bold mb-4 text-dark"><i class="fa-solid fa-plus text-primary me-2"></i> Yeni Emanet Ver</h4>

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label class="form-label" style="font-weight: 600;">Emanet Edilecek Kitap</label>
                    <select asp-for="KitapId" class="form-select" required>
                        <option value="">-- Kitap Seçin --</option>
                        @if (ViewBag.Kitaplar != null)
                        {
                            foreach (var item in (List<LibraryMVC.Models.Kitap>)ViewBag.Kitaplar)
                            {
                                <option value="@item.Id">@item.Baslik</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="KitapId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label" style="font-weight: 600;">Teslim Alan Üye</label>
                    <select asp-for="UyeId" class="form-select" required>
                        <option value="">-- Üye Seçin --</option>
                        @if (ViewBag.Uyeler != null)
                        {
                            foreach (var item in (List<LibraryMVC.Models.Uye>)ViewBag.Uyeler)
                            {
                                <option value="@item.Id">@item.AdSoyad</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="UyeId" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label" style="font-weight: 600;">Emanet Tarihi</label>
                        <input type="date" asp-for="EmanetTarihi" class="form-control" value="@(DateTime.Now.ToString("yyyy-MM-dd"))" required />
                        <span asp-validation-for="EmanetTarihi" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label" style="font-weight: 600;">Başlangıç Durumu</label>
                        <select asp-for="Durum" class="form-select" required>
                            <option value="Emanette" selected>Emanette</option>
                            <option value="Gecikmiş">Gecikmiş</option>
                        </select>
                        <span asp-validation-for="Durum" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a href="/Emanet/Index" class="btn btn-outline-secondary px-4">İptal</a>
                    <button type="submit" class="btn btn-primary px-5">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>
