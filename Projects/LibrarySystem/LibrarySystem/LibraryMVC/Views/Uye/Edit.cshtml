@model LibraryMVC.Models.Uye
@{
    ViewData["Title"] = "Üye Düzenle";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card card-custom p-4">
            <h4 class="fw-bold mb-4 text-dark"><i class="fa-solid fa-user-gear text-warning me-2"></i> Üye Düzenle</h4>

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />

            <form asp-action="Edit" method="post">
                <div class="mb-3">
                    <label class="form-label" style="font-weight: 600;">Adı Soyadı</label>
                    <input type="text" asp-for="AdSoyad" class="form-control" required />
                    <span asp-validation-for="AdSoyad" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label" style="font-weight: 600;">E-Posta Adresi</label>
                    <input type="email" asp-for="Eposta" class="form-control" required />
                    <span asp-validation-for="Eposta" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label" style="font-weight: 600;">Telefon Numarası</label>
                    <input type="text" asp-for="Telefon" class="form-control" required />
                    <span asp-validation-for="Telefon" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label" style="font-weight: 600;">Kayıt Tarihi</label>
                    <input type="date" asp-for="KayitTarihi" class="form-control" value="@(Model.KayitTarihi.ToString("yyyy-MM-dd"))" required />
                    <span asp-validation-for="KayitTarihi" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between">
                    <a href="/Uye/Index" class="btn btn-outline-secondary px-4">İptal</a>
                    <button type="submit" class="btn btn-warning px-5">Güncelle</button>
                </div>
            </form>
        </div>
    </div>
</div>
