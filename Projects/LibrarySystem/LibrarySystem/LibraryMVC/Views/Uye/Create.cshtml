@model LibraryMVC.Models.Uye
@{
    ViewData["Title"] = "Yeni Üye Kaydet";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card card-custom p-4">
            <h4 class="fw-bold mb-4 text-dark"><i class="fa-solid fa-user-plus text-primary me-2"></i> Yeni Üye Kaydet</h4>

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label class="form-label" style="font-weight: 600;">Adı Soyadı</label>
                    <input type="text" asp-for="AdSoyad" class="form-control" placeholder="Üyenin adını ve soyadını girin..." required />
                    <span asp-validation-for="AdSoyad" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label" style="font-weight: 600;">E-Posta Adresi</label>
                    <input type="email" asp-for="Eposta" class="form-control" placeholder="uye@mail.com" required />
                    <span asp-validation-for="Eposta" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label" style="font-weight: 600;">Telefon Numarası</label>
                    <input type="text" asp-for="Telefon" class="form-control" placeholder="05XXXXXXXXX" required />
                    <span asp-validation-for="Telefon" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label" style="font-weight: 600;">Kayıt Tarihi</label>
                    <input type="date" asp-for="KayitTarihi" class="form-control" value="@(DateTime.Now.ToString("yyyy-MM-dd"))" required />
                    <span asp-validation-for="KayitTarihi" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between">
                    <a href="/Uye/Index" class="btn btn-outline-secondary px-4">İptal</a>
                    <button type="submit" class="btn btn-primary px-5">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>
