@model LibraryMVC.Models.Yazar
@{
    ViewData["Title"] = "Yeni Yazar Ekle";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card card-custom p-4">
            <h4 class="fw-bold mb-4 text-dark"><i class="fa-solid fa-plus text-primary me-2"></i> Yeni Yazar Ekle</h4>

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label class="form-label" style="font-weight: 600;">Adı Soyadı</label>
                    <input type="text" asp-for="AdSoyad" class="form-control" placeholder="Yazarın adını ve soyadını girin..." required />
                    <span asp-validation-for="AdSoyad" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label" style="font-weight: 600;">Doğum Tarihi</label>
                    <input type="date" asp-for="DogumTarihi" class="form-control" />
                    <span asp-validation-for="DogumTarihi" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label" style="font-weight: 600;">Biyografisi</label>
                    <textarea asp-for="Biyografi" class="form-control" rows="5" placeholder="Yazarın kısa biyografisini buraya girin..."></textarea>
                    <span asp-validation-for="Biyografi" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between">
                    <a href="/Yazar/Index" class="btn btn-outline-secondary px-4">İptal</a>
                    <button type="submit" class="btn btn-primary px-5">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>
