@model List<LibraryMVC.Models.Kitap>
@{
    ViewData["Title"] = "Kitaplar";
}

<div class="card card-custom p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-book text-primary me-2"></i> Kitaplar</h4>
        <a href="/Kitap/Create" class="btn btn-primary"><i class="fa-solid fa-plus me-1"></i> Yeni Kitap Ekle</a>
    </div>

    <!-- ARAMA VE RAPORLAMA BARBARI -->
    <div class="row mb-3 g-2">
        <div class="col-md-6">
            <form method="get" action="/Kitap/Index" class="d-flex">
                <input type="text" name="search" class="form-control me-2" placeholder="Kitap adı, yazar veya ISBN ara..." value="@ViewBag.Search" />
                <button type="submit" class="btn btn-outline-primary px-3">Ara</button>
                @if (!string.IsNullOrEmpty(ViewBag.Search))
                {
                    <a href="/Kitap/Index" class="btn btn-outline-secondary ms-1">Temizle</a>
                }
            </form>
        </div>
        <div class="col-md-6 text-md-end">
            <a href="/Kitap/ExportExcel?search=@ViewBag.Search" class="btn btn-success me-1"><i class="fa-solid fa-file-excel me-1"></i> Excel İndir</a>
            <a href="/Kitap/ExportPdf?search=@ViewBag.Search" class="btn btn-danger"><i class="fa-solid fa-file-pdf me-1"></i> PDF İndir</a>
        </div>
    </div>

    <!-- TABLO -->
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th style="width: 80px;">ID</th>
                    <th>Kitap Başlığı</th>
                    <th>Yazar</th>
                    <th>ISBN</th>
                    <th>Basım Yılı</th>
                    <th>Sayfa Sayısı</th>
                    <th style="width: 180px;" class="text-center">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td class="fw-semibold text-primary">@item.Baslik</td>
                            <td>@item.YazarAdSoyad</td>
                            <td><code class="text-dark">@item.ISBN</code></td>
                            <td>@item.BasimYili</td>
                            <td>@item.SayfaSayisi</td>
                            <td class="text-center">
                                <a href="/Kitap/Edit/@item.Id" class="btn btn-sm btn-outline-warning me-1"><i class="fa-solid fa-edit"></i> Düzenle</a>
                                <form action="/Kitap/Delete/@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Bu kitabı silmek istediğinize emin misiniz?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i> Sil</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted">Kayıtlı kitap bulunamadı.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
