@model IEnumerable<SiparisSistemi.Models.Urunler>;


<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>👤 Ürünler</h3>

        <a asp-action="Create" class="btn btn-primary">
            + Yeni Ürün
        </a>
    </div>

    <!-- ARAMA -->
    <form method="get" asp-action="Index" class="mb-3">
        <div class="input-group">
            <input type="text" name="arama" class="form-control" placeholder="Ürün ara..." />
            <button class="btn btn-outline-primary">Ara</button>
        </div>
    </form>

    <div class="card shadow-sm">

        <div class="card-body p-0">

            <table class="table table-hover mb-0">

                <thead class="table-dark">
                    <tr>
                        <th>@Html.DisplayNameFor(model => model.UrunId)</th>
                        <th>@Html.DisplayNameFor(model => model.UrunAdi)<d</th>
                        <th>@Html.DisplayNameFor(model => model.Fiyat)<</th>
                        <th>@Html.DisplayNameFor(model => model.Stok)<</th>

                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.UrunId</td>
                            <td>@item.UrunAdi</td>
                            <td>@item.Fiyat</td>
                            <td>@item.Stok</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.UrunId"
                                   class="btn btn-sm btn-warning">Düzenle</a>

                                <a asp-action="Delete" asp-route-id="@item.UrunId"
                                   class="btn btn-sm btn-danger">Sil</a>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>

</div>