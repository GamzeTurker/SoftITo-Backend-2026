@model SiparisSistemi.Models.Urunler
@{
    ViewData["Title"] = "Edit";
}
<div class="container py-4">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow border-0">

                <!-- HEADER -->
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">Ürün Düzenle</h4>
                </div>

                <div class="card-body">

                    <!-- HATA MESAJI -->
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <div>@error.ErrorMessage</div>
                            }
                        </div>
                    }

                    <form asp-action="Edit" method="post">

                        <input type="hidden" asp-for="UrunId" />

                        <!-- ÜRÜN ADI -->
                        <div class="mb-3">
                            <label class="form-label">Ürün Adı</label>
                            <input asp-for="UrunAdi" class="form-control" />
                        </div>

                        <!-- FİYAT -->
                        <div class="mb-3">
                            <label class="form-label">Fiyat</label>
                            <input asp-for="Fiyat" type="number" step="0.01" class="form-control" />
                        </div>

                        <!-- STOK (Normal elle girilebilir sayı alanı) -->
                        <div class="mb-3">
                            <label class="form-label">Stok</label>
                            <input asp-for="Stok" type="number" class="form-control" min="0" />
                        </div>

                        <button class="btn btn-primary w-100">
                            Güncelle
                        </button>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>