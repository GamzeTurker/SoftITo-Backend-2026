@model IEnumerable<SiparisSistemi.Models.Musteriler>;


<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>👤 Müşteriler</h3>

        <a asp-action="Create" class="btn btn-primary">
            + Yeni Müşteri
        </a>
    </div>

    <!-- ARAMA -->
    <form method="get" class="mb-3">
        <div class="input-group">
            <input type="text" name="arama" class="form-control" placeholder="Müşteri ara..." />
            <button class="btn btn-outline-primary">Ara</button>
        </div>
    </form>

    <div class="card shadow-sm">

        <div class="card-body p-0">

            <table class="table table-hover mb-0">

                <thead class="table-dark">
                    <tr>
                        <th>@Html.DisplayNameFor(model=>model.MusteriId)</th>
                        <th>@Html.DisplayNameFor(model => model.MusteriAdSoyad)<d</th>
                        <th>@Html.DisplayNameFor(model => model.Telefon)<</th>
                        <th>@Html.DisplayNameFor(model => model.DogumTarihi)<</th>
                        
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.MusteriId</td>
                            <td>@item.MusteriAdSoyad</td>
                            <td>@item.Telefon</td>
                            <td>@item.DogumTarihi.ToString("dd.MM.yyyy")</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.MusteriId"
                                   class="btn btn-sm btn-warning">Düzenle</a>

                                <a asp-action="Delete" asp-route-id="@item.MusteriId"
                                   class="btn btn-sm btn-danger">Sil</a>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>

</div>