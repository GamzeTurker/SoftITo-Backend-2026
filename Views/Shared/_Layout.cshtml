<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Sipariş Yönetim Sistemi</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
            body{
                background-color:#f8f9fa;
            }

            .navbar{
                box-shadow:0 2px 10px rgba(0,0,0,.08);
            }

            .content-wrapper{
                min-height:80vh;
            }

            footer{
                background:#212529;
                color:white;
            }
    </style>
</head>
<body>

    <!-- Navbar -->

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">

            <a class="navbar-brand fw-bold" href="#">
                Sipariş Sistemi
            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#menu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="menu">

                <ul class="navbar-nav ms-auto">

                    <li class="nav-item">
                        <a asp-controller="Siparis"
                           asp-action="Create"
                           class="nav-link">
                            Sipariş Oluştur
                        </a>
                    </li>

                    <li class="nav-item">
                        <a asp-controller="Siparis"
                           asp-action="Index"
                           class="nav-link">
                            Siparişler
                        </a>
                    </li>

                    <li class="nav-item">
                        <a asp-controller="Musteri"
                           asp-action="Index"
                           class="nav-link">
                            Müşteriler
                        </a>
                    </li>

                    <li class="nav-item">
                        <a asp-controller="Urun"
                           asp-action="Index"
                           class="nav-link">
                            Ürünler
                        </a>
                    </li>

                    <li class="nav-item">
                        <a asp-controller="Rapor"
                           asp-action="Index"
                           class="nav-link">
                            Raporlar
                        </a>
                    </li>

                </ul>

            </div>

        </div>
    </nav>

    <!-- Content -->

    <div class="container content-wrapper py-5">

        @RenderBody()

    </div>

    <!-- Footer -->

    <footer class="py-4 mt-5">
        <div class="container text-center">

            <h6 class="mb-2">
                Sipariş Yönetim Sistemi
            </h6>

            <small>
                © 2025 Tüm Hakları Saklıdır
            </small>

        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>