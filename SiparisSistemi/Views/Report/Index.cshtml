@{
    ViewData["Title"] = "Rapor Seçim Paneli";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-6">

            <div class="card shadow border-0">

                <!-- HEADER -->
                <div class="card-header bg-dark text-white text-center">
                    <h4 class="mb-0">Sipariş Sistemi Raporları</h4>
                </div>

                <!-- CARD BODY -->
                <div class="card-body p-4">

                    <form asp-action="Index" method="post">

                        <div class="mb-4">
                            <label class="form-label fw-bold text-secondary">Görüntülemek İstediğiniz Raporu Seçiniz:</label>

                            <select name="rapor" class="form-select form-select-lg shadow-sm" required>
                                <option value="">--- Rapor Seçiniz ---</option>

                                <optgroup label="İlişkili Raporlar ">
                                    <option value="TumSiparisDetay">Detaylı Sipariş Raporu </option>
                                    <option value="MusteriSiparisOzeti">Müşteri Sipariş Özeti </option>
                                    <option value="UrunSiparisDetaylari">Ürün Sipariş Detayları </option>
                                </optgroup>

                                <optgroup label="Analiz Raporları ">
                                    <option value="UrunSatisAnalizi">Ürün Satış Analizi</option>
                                </optgroup>

                                <optgroup label="Filtreli Raporlar ">
                                    <option value="KritikStokUrunler">Kritik Stoktaki Ürünler</option>
                                    <option value="AktifSiparisler">Aktif Siparişler</option>
                                </optgroup>
                            </select>
                        </div>

                        <!-- SUBMIT BUTTON -->
                        <button type="submit" class="btn btn-primary btn-lg w-100 shadow-sm">
                            Raporu Görüntüle
                        </button>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>