@model IEnumerable<SiparisSistemi.Models.Report>
@{
    ViewData["Title"] = "Kritik Stoktaki Ürünler (Stok < 10)";
}

<div class="container py-4">

    <div class="card shadow-sm border-danger border">

        <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">⚠️ Kritik Stoktaki Ürünler (Stok < 10)</h4>
            <a asp-action="Index" class="btn btn-light btn-sm text-danger fw-bold">Geri Dön</a>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-3">Ürün Adı</th>
                            <th>Fiyat</th>
                            <th class="pe-3">Kalan Stok</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="table-danger">
                                <td class="ps-3 fw-bold">@item.UrunAdi</td>
                                <td>@item.Fiyat.ToString("N2") ₺</td>
                                <td class="pe-3 text-danger fw-bold">@item.Stok Adet</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>

</div>